/**app.wxss - 图书馆柔和风格全局样式**/

page {
  --bg-primary: #ffffff;
  --bg-secondary: #f8f9fa;
  --bg-card: rgba(255, 255, 255, 0.95);
  --primary: #6b9bc3;
  --primary-light: #a8c5de;
  --primary-dark: #4a7ba7;
  --secondary: #8fbc8f;
  --accent: #d4a574;
  --text-primary: #3d4f5f;
  --text-secondary: #7a8b9a;
  --border-color: rgba(107, 155, 195, 0.2);
}

page {
  background: linear-gradient(180deg, #f5f9fc 0%, #ffffff 100%);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  min-height: 100vh;
}

.container {
  min-height: 100vh;
  padding: 20rpx;
}

.card {
  background: var(--bg-card);
  border: 1rpx solid var(--border-color);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(107, 155, 195, 0.08);
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  color: #fff;
  font-weight: 500;
  border-radius: 50rpx;
  padding: 24rpx 0;
  text-align: center;
  font-size: 28rpx;
  border: none;
  box-shadow: 0 4rpx 15rpx rgba(107, 155, 195, 0.25);
}

.btn-primary:active {
  transform: scale(0.98);
  background: linear-gradient(135deg, var(--primary-dark), var(--primary));
}

.btn-secondary {
  background: transparent;
  color: var(--primary);
  border: 2rpx solid var(--primary);
  border-radius: 50rpx;
  padding: 24rpx 0;
  text-align: center;
  font-size: 28rpx;
}

.text-primary {
  color: var(--primary);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-center {
  text-align: center;
}

input {
  background: #f8f9fa;
  border: 1rpx solid var(--border-color);
  border-radius: 15rpx;
  padding: 20rpx 25rpx;
  color: var(--text-primary);
  font-size: 28rpx;
}

input::placeholder {
  color: #b0bec5;
}

button {
  background: transparent;
  border: none;
  padding: 0;
}

.list-item {
  background: var(--bg-card);
  border: 1rpx solid var(--border-color);
  border-radius: 15rpx;
  padding: 25rpx 30rpx;
  margin-bottom: 15rpx;
}

.badge {
  background: linear-gradient(135deg, var(--secondary), var(--primary-light));
  color: #fff;
  padding: 5rpx 15rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.tab-bar {
  background: #ffffff !important;
  border-top: 1rpx solid var(--border-color);
}

@keyframes float {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-5rpx);
  }
}
