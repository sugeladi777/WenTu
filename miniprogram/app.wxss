/**app.wxss**/
.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

/* 通用样式 */
.page-container {
  padding: 20rpx;
}

.card {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.btn-primary {
  background: #3cc51f;
  color: #fff;
  border-radius: 8rpx;
  padding: 20rpx 0;
  text-align: center;
  font-size: 28rpx;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-secondary {
  background: #fff;
  color: #3cc51f;
  border: 1rpx solid #3cc51f;
  border-radius: 8rpx;
  padding: 20rpx 0;
  text-align: center;
  font-size: 28rpx;
}

.text-primary {
  color: #3cc51f;
}

.text-gray {
  color: #999;
}

.text-center {
  text-align: center;
}
