/* 全局样式 - 马卡龙清新风格 */
page {
  background: #faf9f7;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  color: #5a5a5a;
}

/* 通用卡片样式 */
.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

/* 主色调按钮 */
.btn-primary {
  background: linear-gradient(135deg, #ffaaa5 0%, #ffd3b6 100%);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-primary::after {
  border: none;
}

/* 次要按钮 */
.btn-secondary {
  background: #dcedc1;
  color: #6b8e23;
  border: none;
  border-radius: 50rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}

.tag-primary {
  background: linear-gradient(135deg, #ffd3b6 0%, #dcedc1 100%);
  color: #c75b39;
}

.tag-success {
  background: #a8e6cf;
  color: #2e8b57;
}

.tag-warning {
  background: #ffd3b6;
  color: #c75b39;
}

/* 输入框样式 */
.input {
  background: #faf9f7;
  border: 2rpx solid #ffd3b6;
  border-radius: 16rpx;
  padding: 20rpx 30rpx;
  font-size: 28rpx;
}

.input:focus {
  border-color: #ffaaa5;
}
