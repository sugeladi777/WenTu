<view class="container">
  <view class="hero-card">
    <text class="hero-kicker">管理员后台</text>
    <text class="hero-title">{{semester ? semester.name : '暂无学期'}}</text>
    <text class="hero-subtitle">这里只保留创建学期和志愿者名单。点击姓名可查看该志愿者的班次、签到签退、工资发放和更多信息。</text>
  </view>

  <view class="card section-card">
    <view class="section-head">
      <text class="section-title">创建学期</text>
      <text class="section-desc">新建学期后，班次与工资统计都会围绕当前学期展开。</text>
    </view>

    <input
      class="soft-input"
      placeholder="输入学期名称，例如 2026 春季学期"
      value="{{createSemesterName}}"
      bindinput="onSemesterNameInput"
    />

    <view class="picker-row">
      <picker class="picker-field" mode="date" value="{{createSemesterStart}}" bindchange="onSemesterStartChange">
        <view class="picker-inner">
          <text class="picker-label">开始日期</text>
          <text class="picker-value">{{createSemesterStart || '选择日期'}}</text>
        </view>
      </picker>
      <picker class="picker-field" mode="date" value="{{createSemesterEnd}}" bindchange="onSemesterEndChange">
        <view class="picker-inner">
          <text class="picker-label">结束日期</text>
          <text class="picker-value">{{createSemesterEnd || '选择日期'}}</text>
        </view>
      </picker>
    </view>

    <button class="action-btn" hover-class="tap-button-hover" bindtap="onCreateSemester" loading="{{loading}}">
      创建学期
    </button>
  </view>

  <view class="list-head">
    <view>
      <text class="section-title">志愿者列表</text>
      <text class="section-desc">当前共 {{userCount}} 人</text>
    </view>
    <text class="semester-pill" wx:if="{{semester}}">当前学期：{{semester.name}}</text>
  </view>

  <view class="user-list" wx:if="{{userList.length}}">
    <view
      class="user-card card"
      wx:for="{{userList}}"
      wx:key="_id"
      data-userid="{{item._id}}"
      hover-class="tap-card-hover"
      bindtap="onOpenUserDetail">
      <view class="user-main">
        <view class="user-copy">
          <text class="user-name">{{item.displayName}}</text>
          <text class="user-meta">学号 {{item.studentId || '未填写'}}</text>
        </view>
        <view class="user-side">
          <text class="detail-link">查看详情</text>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-card card" wx:else>
    <text class="empty-title">暂无用户</text>
    <text class="empty-desc">当前还没有可查看的志愿者账号。</text>
  </view>
</view>
