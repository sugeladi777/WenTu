.container {
  padding: 24rpx 24rpx 40rpx;
}

.hero-card {
  padding: 36rpx 30rpx;
  border-radius: 40rpx;
  background:
    radial-gradient(circle at 88% 14%, rgba(255, 255, 255, 0.82), transparent 28%),
    linear-gradient(135deg, #ffe0d5 0%, #e8ddff 52%, #dff4ea 100%);
  color: #6c6078;
  box-shadow:
    0 24rpx 56rpx rgba(217, 190, 212, 0.24),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.64);
}

.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.hero-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.hero-kicker {
  font-size: 22rpx;
  letter-spacing: 3rpx;
  opacity: 0.82;
}

.hero-title {
  display: block;
  margin-top: 16rpx;
  font-size: 40rpx;
  font-weight: 800;
}

.hero-subtitle {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.72;
  opacity: 0.88;
}

.hero-metrics {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 24rpx;
}

.hero-metric {
  padding: 20rpx 18rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.68);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.54);
}

.hero-metric-value {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
  color: #6a5d78;
}

.hero-metric-label {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #9f92b0;
}

.section-card {
  margin-top: 20rpx;
  padding: 28rpx;
  background:
    radial-gradient(circle at 92% 8%, rgba(255, 255, 255, 0.72), transparent 28%),
    linear-gradient(180deg, rgba(255, 249, 252, 0.98) 0%, rgba(255, 255, 255, 0.98) 100%);
}

.section-head {
  display: flex;
  flex-direction: column;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #6d607a;
}

.section-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #a79cb3;
}

.export-card {
  overflow: hidden;
}

.salary-card {
  overflow: hidden;
}

.range-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 22rpx;
}

.range-block {
  padding: 22rpx 20rpx;
  border-radius: 30rpx;
  background:
    radial-gradient(circle at 92% 10%, rgba(255, 255, 255, 0.7), transparent 28%),
    linear-gradient(180deg, rgba(250, 244, 252, 0.98) 0%, rgba(255, 255, 255, 0.98) 100%);
  box-shadow:
    0 14rpx 28rpx rgba(213, 192, 220, 0.12),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.58);
}

.range-label {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #6d607a;
}

.soft-input {
  width: 100%;
  height: 94rpx;
  margin-top: 20rpx;
  padding: 0 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(255, 250, 252, 0.98) 0%, rgba(255, 255, 255, 0.98) 100%);
  border: 1rpx solid rgba(235, 221, 241, 0.9);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.64);
  box-sizing: border-box;
  font-size: 26rpx;
  color: #6d607a;
}

.picker-row {
  display: flex;
  gap: 14rpx;
  margin-top: 18rpx;
}

.picker-row.compact {
  margin-top: 14rpx;
}

.picker-field {
  flex: 1;
}

.picker-field.time-field {
  flex: 0.72;
}

.picker-inner {
  padding: 22rpx 22rpx;
  border-radius: 26rpx;
  background: linear-gradient(180deg, rgba(251, 246, 253, 0.98) 0%, rgba(255, 255, 255, 0.98) 100%);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.54);
}

.picker-label {
  display: block;
  font-size: 20rpx;
  color: #aa9fb8;
}

.picker-value {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6d607a;
  font-weight: 700;
}

.export-quick-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 18rpx;
}

.ghost-btn {
  margin: 0;
  padding: 0 24rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #8b789e;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.42) 0%, rgba(255, 255, 255, 0) 32%),
    linear-gradient(135deg, rgba(244, 236, 250, 0.98) 0%, rgba(255, 245, 239, 0.98) 100%);
  box-shadow:
    0 10rpx 20rpx rgba(214, 194, 219, 0.12),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.56);
}

.export-meta {
  flex: 1;
  font-size: 20rpx;
  line-height: 1.6;
  text-align: right;
  color: #a397b0;
}

.action-btn {
  width: 100%;
  height: 92rpx;
  margin-top: 20rpx;
  line-height: 92rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.4) 0%, rgba(255, 255, 255, 0) 32%),
    linear-gradient(145deg, #ffbfb0 0%, #ffc2e1 54%, #ffe6a7 100%);
  color: #7a657d;
  box-shadow:
    0 14rpx 0 rgba(161, 115, 133, 0.14),
    0 26rpx 46rpx rgba(226, 188, 199, 0.24),
    inset 0 4rpx 0 rgba(255, 255, 255, 0.52);
}

.salary-action-btn {
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.4) 0%, rgba(255, 255, 255, 0) 32%),
    linear-gradient(145deg, #c8efd9 0%, #d8e6ff 54%, #ffe8b1 100%);
  color: #677b95;
}

.export-hint {
  display: block;
  margin-top: 14rpx;
  font-size: 20rpx;
  line-height: 1.7;
  color: #a79cb3;
}

.application-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 22rpx;
}

.application-card {
  padding: 24rpx 22rpx;
  border-radius: 28rpx;
  background:
    radial-gradient(circle at 92% 8%, rgba(255, 255, 255, 0.72), transparent 28%),
    linear-gradient(180deg, rgba(255, 250, 252, 0.98) 0%, rgba(255, 255, 255, 0.98) 100%);
  box-shadow:
    0 16rpx 34rpx rgba(208, 188, 211, 0.16),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.58);
}

.application-copy {
  display: flex;
  flex-direction: column;
}

.application-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #6c6078;
}

.application-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #a398b0;
}

.application-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.mini-action-btn {
  flex: 1;
  height: 78rpx;
  line-height: 78rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 700;
  box-shadow:
    0 10rpx 0 rgba(173, 143, 170, 0.1),
    0 18rpx 30rpx rgba(221, 190, 210, 0.14),
    inset 0 4rpx 0 rgba(255, 255, 255, 0.52);
}

.mini-action-btn.approve {
  color: #6788a1;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.4) 0%, rgba(255, 255, 255, 0) 32%),
    linear-gradient(145deg, #cdeedc 0%, #d7e4ff 54%, #fff0b8 100%);
}

.mini-action-btn.reject {
  color: #ca8794;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.4) 0%, rgba(255, 255, 255, 0) 32%),
    linear-gradient(145deg, #ffc2cd 0%, #ffd8ec 54%, #fff1f4 100%);
}

.list-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.semester-pill {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.88);
  color: #8f84a2;
  font-size: 20rpx;
}

.semester-pill.secondary {
  background: rgba(244, 238, 250, 0.92);
  color: #8c7aa2;
}

.semester-pill.ghost {
  background: rgba(255, 255, 255, 0.62);
  color: #a69ab8;
}

.search-shell {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 20rpx;
  padding: 14rpx 18rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(251, 246, 253, 0.98) 0%, rgba(255, 255, 255, 0.98) 100%);
  box-shadow:
    0 12rpx 26rpx rgba(214, 195, 219, 0.1),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.56);
}

.search-input {
  flex: 1;
  min-height: 46rpx;
  font-size: 26rpx;
  color: #6d607a;
}

.clear-search {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(244, 236, 250, 0.96);
  color: #907da5;
  font-size: 22rpx;
}

.user-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 18rpx;
}

.user-card {
  padding: 26rpx 24rpx;
  border-radius: 32rpx;
  background:
    radial-gradient(circle at 92% 8%, rgba(255, 255, 255, 0.72), transparent 28%),
    linear-gradient(180deg, rgba(255, 249, 252, 0.98) 0%, rgba(255, 255, 255, 0.98) 100%);
  box-shadow:
    0 16rpx 34rpx rgba(208, 188, 211, 0.16),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.58);
}

.user-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.user-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.user-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.user-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #6c6078;
}

.user-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #a398b0;
}

.user-side {
  display: flex;
  align-items: center;
}

.role-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.role-chip.member {
  background: rgba(255, 236, 228, 0.92);
  color: #cb8a78;
}

.role-chip.leader {
  background: rgba(236, 228, 248, 0.94);
  color: #8c7aac;
}

.role-chip.admin {
  background: rgba(223, 235, 255, 0.94);
  color: #768cc1;
}

.detail-link {
  font-size: 22rpx;
  color: #8f84a2;
}

.empty-card {
  margin-top: 18rpx;
  padding: 34rpx 28rpx;
  text-align: center;
  border-radius: 32rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(255, 252, 255, 0.92) 100%);
  box-shadow:
    0 20rpx 42rpx rgba(207, 185, 210, 0.12),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.56);
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #6d607a;
}

.empty-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #a79cb3;
}
