<view class="container">
  <view class="hero-card" wx:if="{{userInfo}}">
    <view class="hero-top">
      <view class="hero-copy">
        <text class="hero-kicker">志愿者详情</text>
        <text class="hero-title">{{userInfo.displayName}}</text>
        <text class="hero-subtitle">学号 {{userInfo.studentId || '未填写'}} · {{userInfo.grantedRolesText || '志愿者'}}</text>
      </view>
      <text class="role-chip {{userInfo.roleClass}}">{{userInfo.roleBadgeText}}</text>
    </view>
  </view>

  <view class="shift-section">
    <view class="section-head standalone">
      <text class="section-title">全部班次</text>
      <text class="section-desc">点击班次可查看详情。</text>
    </view>

    <view class="week-overview card" wx:if="{{weeklyShifts.length > 0}}">
      <text class="week-overview-kicker">本周排班</text>
      <text class="week-overview-text">{{currentWeekLabel}}</text>
    </view>

    <swiper
      class="week-swiper"
      indicator-dots="{{weeklyShifts.length > 1}}"
      current="{{currentWeekIndex}}"
      bindchange="onWeekChange"
      wx:if="{{weeklyShifts.length > 0}}">
      <swiper-item wx:for="{{weeklyShifts}}" wx:for-item="week" wx:key="weekStart">
        <view class="week-card">
          <view class="calendar-day-header">
            <view class="calendar-day-header-cell" wx:for="{{weekDayNames}}" wx:for-index="dayIdx" wx:key="index">
              <text class="calendar-day-name">{{item}}</text>
              <text class="calendar-day-date">{{week.dates[dayIdx]}}</text>
            </view>
          </view>

          <view class="calendar-day-content">
            <block wx:for="{{week.days}}" wx:key="index">
              <view class="calendar-day-content-cell">
                <block wx:if="{{item.length > 0}}">
                  <block wx:for="{{item}}" wx:for-item="shift" wx:key="_id">
                    <view
                      class="calendar-shift-item {{shift.shiftTypeClass}}"
                      data-id="{{shift._id}}"
                      hover-class="tap-card-hover"
                      bindtap="onOpenShift">
                      <text class="calendar-shift-name">{{shift.shiftName}}</text>
                      <text class="calendar-shift-time">{{shift.startTime}}</text>
                      <text class="calendar-shift-salary" wx:if="{{shift.salaryPaid}}">工资已发</text>
                      <text class="calendar-shift-type" wx:if="{{shift.shiftType > 0}}">{{shift.shiftTypeText}}</text>
                    </view>
                  </block>
                </block>
              </view>
            </block>
          </view>
        </view>
      </swiper-item>
    </swiper>

    <view class="empty-card card" wx:if="{{!loading && shiftList.length === 0}}">
      <text class="empty-title">暂无班次安排</text>
      <text class="empty-desc">当前没有可显示的排班记录。</text>
    </view>
  </view>

  <view class="shift-section">
    <view class="section-head standalone">
      <text class="section-title">固定班次任命</text>
      <text class="section-desc">点选表格即可任命、改派或撤销班负。</text>
    </view>

    <scroll-view class="table-scroll" scroll-x enhanced show-scrollbar="{{false}}" wx:if="{{shiftTableRows.length}}">
      <view class="schedule-table">
        <view class="table-header">
          <view class="th shift-col">班次</view>
          <view
            class="th weekday-col"
            wx:for="{{weekDays}}"
            wx:for-item="day"
            wx:key="index">
            <text class="day-name">{{day}}</text>
          </view>
        </view>

        <view
          class="table-row"
          wx:for="{{shiftTableRows}}"
          wx:for-item="row"
          wx:key="rowKey">
          <view class="td shift-col">
            <text class="shift-name">{{row.shiftName}}</text>
            <text class="shift-time">{{row.timeRange}}</text>
            <text class="shift-capacity">固定 {{row.fixedHoursText}} 小时</text>
          </view>
          <view
            class="td weekday-col"
            wx:for="{{row.cells}}"
            wx:for-item="cell"
            wx:key="index">
            <view
              wx:if="{{cell}}"
              class="leader-slot-btn {{cell.slotStateClass}} {{selectedSlotKey === cell.slotKey ? 'active' : ''}}"
              data-key="{{cell.slotKey}}"
              bindtap="onSelectShiftSlot">
              <text class="slot-main">{{cell.cellTitle}}</text>
              <text class="slot-sub">{{cell.cellSubtitle}}</text>
            </view>
            <view wx:else class="leader-slot-empty">留空</view>
          </view>
        </view>
      </view>
    </scroll-view>

    <view class="card leader-action-card" wx:if="{{selectedShiftSlot}}">
      <view class="leader-action-copy">
        <text class="leader-action-title">{{selectedShiftSlot.shiftName}}</text>
        <text class="leader-action-subtitle">{{selectedShiftSlot.weekdayText}} · {{selectedShiftSlot.timeRange}}</text>
      </view>

      <button
        wx:if="{{selectedShiftSlot.canManageLeader}}"
        class="shift-leader-btn {{selectedShiftSlot.leaderActionClass}} compact"
        hover-class="tap-button-hover"
        bindtap="onToggleShiftLeader"
        data-id="{{selectedShiftSlot.scheduleId}}"
        data-action="{{selectedShiftSlot.leaderAction}}"
        loading="{{leaderActionScheduleId === selectedShiftSlot.scheduleId}}">
        {{selectedShiftSlot.leaderActionText}}
      </button>

      <view wx:else class="shift-leader-disabled">{{selectedShiftSlot.leaderActionText}}</view>
    </view>

    <view class="empty-card card" wx:if="{{!shiftTableRows.length}}">
      <text class="empty-title">暂无固定班次记录</text>
      <text class="empty-desc">当前学期下还没有这个志愿者的固定班次数据。</text>
    </view>
  </view>

  <view class="card metric-section" wx:if="{{overviewCards.length}}">
    <text class="section-title">学期总览</text>
    <view class="metric-grid">
      <view class="metric-card" wx:for="{{overviewCards}}" wx:key="label">
        <text class="metric-value">{{item.value}}</text>
        <text class="metric-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="card metric-section" wx:if="{{attendanceCards.length}}">
    <text class="section-title">考勤情况</text>
    <view class="metric-grid compact">
      <view class="metric-card" wx:for="{{attendanceCards}}" wx:key="label">
        <text class="metric-value">{{item.value}}</text>
        <text class="metric-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="card metric-section" wx:if="{{salaryCards.length}}">
    <text class="section-title">工资发放</text>
    <view class="metric-grid compact">
      <view class="metric-card salary" wx:for="{{salaryCards}}" wx:key="label">
        <text class="metric-value">{{item.value}}</text>
        <text class="metric-label">{{item.label}}</text>
      </view>
    </view>
  </view>
</view>
