.container {
  padding: 24rpx;
}

.hero-card {
  display: flex;
  flex-direction: column;
  padding: 36rpx 30rpx;
  border-radius: 42rpx;
  background:
    radial-gradient(circle at 88% 16%, rgba(255, 255, 255, 0.84), transparent 30%),
    linear-gradient(135deg, #dff4ea 0%, #dce8ff 48%, #ffe3c7 100%);
  box-shadow:
    0 24rpx 60rpx rgba(192, 197, 228, 0.22),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.64);
  color: #66748a;
}

.hero-kicker {
  font-size: 22rpx;
  letter-spacing: 3rpx;
  opacity: 0.82;
}

.hero-title {
  margin-top: 18rpx;
  font-size: 42rpx;
  line-height: 1.28;
  font-weight: 800;
}

.hero-subtitle {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.72;
  opacity: 0.88;
}

.date-card {
  margin-top: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 255, 255, 0.72), transparent 30%),
    linear-gradient(180deg, rgba(255, 249, 252, 0.98) 0%, rgba(255, 255, 255, 0.98) 100%);
}

.date-copy {
  flex: 1;
}

.date-picker {
  min-width: 230rpx;
  padding: 22rpx 24rpx;
  border-radius: 28rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.4) 0%, rgba(255, 255, 255, 0) 34%),
    linear-gradient(145deg, #ccefe0 0%, #d8e3ff 52%, #ffe7bc 100%);
  box-shadow:
    0 12rpx 0 rgba(148, 165, 185, 0.12),
    0 22rpx 36rpx rgba(198, 194, 224, 0.18),
    inset 0 4rpx 0 rgba(255, 255, 255, 0.54);
}

.date-picker-label {
  display: block;
  font-size: 20rpx;
  color: #8c97a8;
}

.date-picker-value {
  display: block;
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 800;
  color: #5f7188;
}

.list-card {
  margin-top: 20rpx;
  padding: 30rpx;
  background:
    radial-gradient(circle at 92% 8%, rgba(255, 255, 255, 0.74), transparent 28%),
    linear-gradient(180deg, rgba(255, 249, 252, 0.98) 0%, rgba(255, 255, 255, 0.98) 100%);
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
}

.quick-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 24rpx;
}

.quick-item {
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 28rpx 22rpx;
  border-radius: 30rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 255, 255, 0.66), transparent 28%),
    linear-gradient(135deg, rgba(230, 246, 238, 0.98) 0%, rgba(239, 243, 255, 0.98) 54%, rgba(255, 244, 236, 0.98) 100%);
  box-shadow:
    0 18rpx 38rpx rgba(203, 217, 210, 0.2),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.58);
}

.item-glow {
  position: absolute;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
}

.item-glow.glow-a {
  top: -26rpx;
  right: 24rpx;
  width: 144rpx;
  height: 144rpx;
}

.item-glow.glow-b {
  left: -18rpx;
  bottom: -24rpx;
  width: 96rpx;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.14);
}

.quick-copy {
  position: relative;
  z-index: 1;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.quick-title {
  flex: 1;
  font-size: 28rpx;
  font-weight: 800;
  color: #65758b;
}

.quick-sub {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #909bad;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.meta-pill,
.status-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
}

.meta-pill {
  color: #8694a7;
  background: rgba(255, 255, 255, 0.72);
}

.status-pill.status-available {
  color: #5f8f7e;
  background: rgba(214, 243, 227, 0.96);
}

.status-pill.status-disabled {
  color: #b07f72;
  background: rgba(255, 236, 219, 0.96);
}

.action-btn {
  position: relative;
  z-index: 1;
  min-width: 190rpx;
  height: 92rpx;
  line-height: 92rpx;
  padding: 0 22rpx;
  border-radius: 28rpx;
  font-size: 24rpx;
  font-weight: 800;
  box-shadow:
    0 12rpx 0 rgba(150, 159, 185, 0.12),
    0 22rpx 38rpx rgba(201, 196, 226, 0.18),
    inset 0 4rpx 0 rgba(255, 255, 255, 0.52);
}

.action-btn.join {
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.4) 0%, rgba(255, 255, 255, 0) 32%),
    linear-gradient(145deg, #cdeedc 0%, #d7e4ff 54%, #fff0b8 100%);
  color: #64879f;
}

.action-btn.disabled {
  background: linear-gradient(180deg, rgba(244, 240, 247, 0.98) 0%, rgba(255, 255, 255, 0.99) 100%);
  color: #a89faf;
  box-shadow:
    0 10rpx 0 rgba(176, 167, 190, 0.08),
    0 18rpx 30rpx rgba(208, 201, 220, 0.12),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.56);
}

.empty {
  margin-top: 20rpx;
  padding: 76rpx 34rpx;
  text-align: center;
  background:
    radial-gradient(circle at 50% 0, rgba(255, 255, 255, 0.76), transparent 36%),
    linear-gradient(180deg, rgba(250, 246, 255, 0.98) 0%, rgba(255, 255, 255, 0.98) 100%);
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #6d607a;
}

.empty-text {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.72;
  color: #a69bb4;
}
