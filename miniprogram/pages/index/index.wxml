<!--pages/index/index.wxml-->
<view class="container">
  <!-- 今日班次信息 -->
  <view class="card shift-info" wx:if="{{todayShifts.length > 0}}">
    <view class="section-title">今日班次</view>
    <view class="shift-tabs">
      <view 
        class="shift-tab {{currentShiftIndex === index ? 'active' : ''}}"
        wx:for="{{todayShifts}}"
        wx:key="_id"
        data-index="{{index}}"
        bindtap="onShiftChange">
        <text class="tab-name">{{item.shiftName}}</text>
        <text class="tab-time">{{item.startTime}} - {{item.endTime}}</text>
      </view>
    </view>
  </view>

  <!-- 无班次提示 -->
  <view class="no-shift" wx:if="{{todayShifts.length === 0}}">
    <text class="no-shift-icon">📅</text>
    <text>今日暂无班次</text>
  </view>

  <!-- 签到签退按钮 -->
  <view class="check-section" wx:if="{{todayShifts.length > 0}}">
    <view class="check-time" wx:if="{{hasCheckedIn && !hasCheckedOut}}">
      <text class="time-label">签到时间</text>
      <text class="time-value">{{formatTime(todayRecords[0].checkInTime)}}</text>
    </view>
    
    <button 
      class="btn-check {{hasCheckedOut ? 'checked-out' : (hasCheckedIn ? 'check-out' : 'check-in')}}" 
      bindtap="onCheck"
      disabled="{{hasCheckedOut}}">
      <text class="current-time">{{currentTime}}</text>
      <text class="btn-icon">{{hasCheckedOut ? '✓' : (hasCheckedIn ? '↓' : '↑')}}</text>
      <text class="btn-text">{{hasCheckedOut ? '已完成' : (hasCheckedIn ? '签退' : '签到')}}</text>
    </button>
    
    <view class="check-time" wx:if="{{hasCheckedOut}}">
      <text class="time-label">签退时间</text>
      <text class="time-value">{{formatTime(todayRecords[todayRecords.length - 1].checkOutTime)}}</text>
    </view>
  </view>

  <!-- 今日签到记录（从 schedules 表获取） -->
  <view class="card today-record" wx:if="{{todayRecords.length > 0}}">
    <view class="section-title">今日签到记录</view>
    <view class="record-list">
      <view class="record-item" wx:for="{{todayRecords}}" wx:key="_id">
        <view class="record-header">
          <text class="record-shift">{{item.shiftName || '班次'}}</text>
          <text class="record-status {{item.attendanceStatus === 1 ? 'late' : ''}}">
            {{item.attendanceStatus === 1 ? '迟到' : '正常'}}
          </text>
        </view>
        <view class="record-times">
          <view class="time-block">
            <text class="time-label">签到</text>
            <text class="time-value">{{formatTime(item.checkInTime)}}</text>
          </view>
          <view class="time-block">
            <text class="time-label">签退</text>
            <text class="time-value">{{formatTime(item.checkOutTime) || '--'}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
