<!--pages/index/index.wxml-->
<view class="container">
  <!-- 今日班次信息 -->
  <view class="card shift-info">
    <view class="shift-name">今日班次：{{todayShift.name || '暂无班次'}}</view>
    <view class="shift-time">{{todayShift.startTime || '--:--'}} - {{todayShift.endTime || '--:--'}}</view>
  </view>

  <!-- 签到签退区域 -->
  <view class="card check-buttons">
    <button 
      class="btn-checkin {{hasCheckedIn ? 'disabled' : ''}}" 
      bindtap="onCheckIn"
      disabled="{{hasCheckedIn}}">
      {{hasCheckedIn ? '已签到' : '签到'}}
    </button>
    
    <button 
      class="btn-checkout {{hasCheckedOut || !hasCheckedIn ? 'disabled' : ''}}" 
      bindtap="onCheckOut"
      disabled="{{hasCheckedOut || !hasCheckedIn}}">
      {{hasCheckedOut ? '已签退' : '签退'}}
    </button>
  </view>

  <!-- 加班选择 -->
  <view class="card overtime-section" wx:if="{{hasCheckedIn && !hasCheckedOut}}">
    <view class="section-title">加班时长（可选）</view>
    <view class="overtime-buttons">
      <button data-hours="0" bindtap="onCheckOut">无</button>
      <button data-hours="1" bindtap="onCheckOut">1小时</button>
      <button data-hours="2" bindtap="onCheckOut">2小时</button>
    </view>
  </view>

  <!-- 今日签到记录 -->
  <view class="card today-record" wx:if="{{todayRecord}}">
    <view class="section-title">今日签到记录</view>
    <view class="record-item">
      <text>签到时间：{{todayRecord.checkInTime || '--'}}</text>
    </view>
    <view class="record-item">
      <text>签退时间：{{todayRecord.checkOutTime || '--'}}</text>
    </view>
    <view class="record-item" wx:if="{{todayRecord.overtimeHours > 0}}">
      <text>加班时长：{{todayRecord.overtimeHours}}小时</text>
      <text class="status-tag {{todayRecord.overtimeApproved ? 'approved' : 'pending'}}">
        {{todayRecord.overtimeApproved ? '已审批' : '待审批'}}
      </text>
    </view>
  </view>
</view>
