/* 首页样式 - 马卡龙清新风格 */
.container {
  padding: 20rpx;
  background: linear-gradient(180deg, #faf9f7 0%, #fff5f5 100%);
  min-height: 100vh;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #5a5a5a;
  margin-bottom: 20rpx;
}

.shift-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 10rpx;
}

.shift-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 25rpx 35rpx;
  background: #fff;
  border-radius: 20rpx;
  min-width: 180rpx;
  border: 2rpx solid #f0f0f0;
  transition: all 0.3s ease;
}

.shift-tab.active {
  background: linear-gradient(135deg, #a8e6cf 0%, #dcedc1 100%);
  border-color: #a8e6cf;
  box-shadow: 0 8rpx 25rpx rgba(168, 230, 207, 0.4);
}

.tab-name {
  font-size: 30rpx;
  color: #5a5a5a;
  font-weight: 600;
}

.tab-time {
  font-size: 22rpx;
  color: #aaa;
  margin-top: 8rpx;
}

.shift-tab.active .tab-name,
.shift-tab.active .tab-time {
  color: #2e8b57;
}

.no-shift {
  text-align: center;
  color: #aaa;
  padding: 80rpx;
  font-size: 28rpx;
  background: linear-gradient(135deg, #fff 0%, #f0fff0 100%);
  border-radius: 20rpx;
  border: 2rpx dashed #dcedc1;
}

.no-shift-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  display: block;
}

.check-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.check-time {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}

.time-label {
  font-size: 26rpx;
  color: #aaa;
}

.time-value {
  font-size: 40rpx;
  color: #5a5a5a;
  font-weight: bold;
  margin-top: 8rpx;
}

.btn-check {
  width: 500rpx !important;
  height: 500rpx !important;
  border-radius: 250rpx !important;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: none !important;
  padding: 0 !important;
  margin: 0 !important;
  box-sizing: border-box !important;
  box-shadow: 0 15rpx 50rpx rgba(255, 170, 165, 0.4);
}

.current-time {
  font-size: 50rpx;
  font-weight: bold;
  color: inherit;
  margin-bottom: 10rpx;
  letter-spacing: 2rpx;
}

.btn-check.check-in {
  background: linear-gradient(135deg, #ffaaa5 0%, #ffd3b6 100%) !important;
  color: #fff !important;
}

.btn-check.check-out {
  background: linear-gradient(135deg, #ffd3b6 0%, #dcedc1 100%) !important;
  color: #5a5a5a !important;
}

.btn-check.checked-out {
  background: linear-gradient(135deg, #a8e6cf 0%, #98d8aa 100%) !important;
  color: #fff !important;
}

.btn-check[disabled] {
  opacity: 0.8;
}

.btn-icon {
  font-size: 100rpx;
  margin-bottom: 15rpx;
}

.btn-text {
  font-size: 40rpx;
  font-weight: bold;
}

.today-record {
  margin-top: 20rpx;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.record-item {
  padding: 25rpx;
  background: linear-gradient(135deg, #fff 0%, #faf9f7 100%);
  border-radius: 20rpx;
  border: 1rpx solid #f0f0f0;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.record-shift {
  font-size: 28rpx;
  font-weight: 600;
  color: #5a5a5a;
}

.record-status {
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #a8e6cf 0%, #dcedc1 100%);
  color: #2e8b57;
  border-radius: 30rpx;
}

.record-status.late {
  background: linear-gradient(135deg, #ffd3b6 0%, #ffaaa5 100%);
  color: #c75b39;
}

.record-times {
  display: flex;
  gap: 60rpx;
}

.time-block {
  display: flex;
  flex-direction: column;
}

.time-block .time-label {
  font-size: 22rpx;
  color: #aaa;
}

.time-block .time-value {
  font-size: 30rpx;
  color: #5a5a5a;
  font-weight: 500;
}
