.container {
  padding: 24rpx 24rpx 48rpx;
}

.hero-card {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 20rpx;
  border-radius: 42rpx;
  color: #6c5f79;
  box-shadow:
    0 24rpx 60rpx rgba(224, 188, 200, 0.24),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.62);
}

.hero-card.member {
  background:
    radial-gradient(circle at 86% 18%, rgba(255, 255, 255, 0.88), transparent 30%),
    linear-gradient(135deg, #ffd8d6 0%, #ffe8c3 42%, #dff6e9 100%);
}

.hero-card.leader {
  background:
    radial-gradient(circle at 86% 18%, rgba(255, 255, 255, 0.88), transparent 30%),
    linear-gradient(135deg, #ffe1d1 0%, #fff3c9 44%, #dcecff 100%);
}

.hero-card.admin {
  background:
    radial-gradient(circle at 86% 18%, rgba(255, 255, 255, 0.9), transparent 30%),
    linear-gradient(135deg, #e0efff 0%, #e9e7ff 42%, #f8e6ff 100%);
}

.hero-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.hero-kicker {
  font-size: 22rpx;
  letter-spacing: 3rpx;
  opacity: 0.8;
}

.hero-title {
  margin-top: 18rpx;
  font-size: 42rpx;
  line-height: 1.28;
  font-weight: 700;
}

.hero-subtitle {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.72;
  opacity: 0.86;
}

.hero-badge {
  width: 170rpx;
  min-height: 170rpx;
  padding: 18rpx 12rpx;
  box-sizing: border-box;
  border-radius: 34rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.52);
  box-shadow:
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.72),
    0 16rpx 34rpx rgba(210, 192, 219, 0.16);
}

.hero-badge-value {
  font-size: 54rpx;
  font-weight: 800;
}

.hero-badge-label {
  margin-top: 10rpx;
  font-size: 22rpx;
  opacity: 0.86;
}

.stats-grid {
  display: grid;
  gap: 18rpx;
  margin-bottom: 20rpx;
}

.stats-grid.two,
.stats-grid.four {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.stat-card {
  padding: 28rpx 24rpx;
  border-radius: 30rpx;
  box-shadow:
    0 18rpx 42rpx rgba(212, 191, 200, 0.18),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.62);
}

.stat-card.warm {
  background: linear-gradient(135deg, rgba(255, 231, 224, 0.98) 0%, rgba(255, 249, 244, 1) 100%);
}

.stat-card.mint {
  background: linear-gradient(135deg, rgba(224, 247, 236, 0.98) 0%, rgba(248, 255, 252, 1) 100%);
}

.stat-card.blue {
  background: linear-gradient(135deg, rgba(229, 239, 255, 0.98) 0%, rgba(247, 251, 255, 1) 100%);
}

.stat-card.yellow {
  background: linear-gradient(135deg, rgba(255, 243, 215, 0.98) 0%, rgba(255, 252, 242, 1) 100%);
}

.stat-card.lavender {
  background: linear-gradient(135deg, rgba(241, 232, 255, 0.98) 0%, rgba(252, 248, 255, 1) 100%);
}

.stat-value {
  display: block;
  font-size: 46rpx;
  font-weight: 800;
  color: #6d607c;
}

.stat-label {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #a095b0;
}

.mission-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 30rpx;
  margin-bottom: 22rpx;
  border-radius: 34rpx;
  box-shadow:
    0 18rpx 40rpx rgba(212, 191, 200, 0.18),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.6);
}

.mission-card.leader {
  background: linear-gradient(135deg, rgba(255, 241, 216, 0.98) 0%, rgba(255, 251, 239, 1) 100%);
}

.mission-card.admin {
  background: linear-gradient(135deg, rgba(228, 239, 255, 0.98) 0%, rgba(248, 251, 255, 1) 100%);
}

.mission-copy {
  flex: 1;
}

.mission-kicker {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #6f627d;
}

.mission-text {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #9e93ad;
}

.mission-btn {
  min-width: 220rpx;
  height: 86rpx;
  line-height: 86rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.5) 0%, rgba(255, 255, 255, 0.1) 100%),
    linear-gradient(135deg, #ffd7cc 0%, #dfe5ff 100%);
  color: #6f617f;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: 0 14rpx 30rpx rgba(216, 192, 202, 0.22);
}

.application-panel {
  padding: 30rpx;
  margin-bottom: 22rpx;
  background:
    radial-gradient(circle at 90% 10%, rgba(255, 255, 255, 0.7), transparent 28%),
    linear-gradient(180deg, rgba(255, 250, 252, 0.98) 0%, rgba(255, 255, 255, 0.98) 100%);
}

.application-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 24rpx;
}

.application-card {
  padding: 24rpx 22rpx;
  border-radius: 28rpx;
  background:
    radial-gradient(circle at 92% 8%, rgba(255, 255, 255, 0.72), transparent 28%),
    linear-gradient(180deg, rgba(255, 250, 252, 0.98) 0%, rgba(255, 255, 255, 0.98) 100%);
  box-shadow:
    0 16rpx 34rpx rgba(208, 188, 211, 0.16),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.58);
}

.application-copy {
  display: flex;
  flex-direction: column;
}

.application-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #6c6078;
}

.application-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #a398b0;
}

.application-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.mini-action-btn {
  flex: 1;
  height: 78rpx;
  line-height: 78rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 700;
  box-shadow:
    0 10rpx 0 rgba(173, 143, 170, 0.1),
    0 18rpx 30rpx rgba(221, 190, 210, 0.14),
    inset 0 4rpx 0 rgba(255, 255, 255, 0.52);
}

.mini-action-btn.approve {
  color: #6788a1;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.4) 0%, rgba(255, 255, 255, 0) 32%),
    linear-gradient(145deg, #cdeedc 0%, #d7e4ff 54%, #fff0b8 100%);
}

.mini-action-btn.reject {
  color: #ca8794;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.4) 0%, rgba(255, 255, 255, 0) 32%),
    linear-gradient(145deg, #ffc2cd 0%, #ffd8ec 54%, #fff1f4 100%);
}

.focus-card {
  padding: 28rpx;
  margin-bottom: 22rpx;
  background:
    radial-gradient(circle at 88% 12%, rgba(255, 255, 255, 0.72), transparent 26%),
    linear-gradient(180deg, rgba(255, 249, 251, 0.98) 0%, rgba(255, 255, 255, 0.98) 100%);
}

.focus-card.compact {
  padding: 26rpx;
}

.focus-card.compact .shift-tabs-scroll {
  margin-top: 20rpx;
}

.focus-heading {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #6d617b;
}

.focus-action {
  display: flex;
  justify-content: center;
  margin-top: 26rpx;
}

.focus-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
}

.focus-kicker {
  display: block;
  font-size: 22rpx;
  color: #d88b83;
  letter-spacing: 2rpx;
}

.focus-title {
  display: block;
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #6d607c;
}

.focus-window {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #a194af;
}

.focus-status,
.record-status {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: rgba(220, 246, 232, 0.9);
  color: #69a288;
}

.focus-status.late,
.record-status.late {
  background: rgba(255, 236, 209, 0.94);
  color: #c98f63;
}

.focus-status.danger,
.record-status.danger {
  background: rgba(255, 226, 231, 0.94);
  color: #cc8696;
}

.focus-status.muted,
.record-status.muted {
  background: rgba(236, 230, 249, 0.94);
  color: #8b7fab;
}

.shift-tabs-scroll {
  margin-top: 22rpx;
  white-space: nowrap;
}

.shift-tabs {
  display: inline-flex;
  gap: 16rpx;
}

.shift-tab {
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 224rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(252, 246, 255, 0.96) 0%, rgba(255, 255, 255, 0.98) 100%);
  border: 1rpx solid rgba(239, 228, 247, 0.72);
  box-shadow: 0 10rpx 24rpx rgba(213, 197, 222, 0.1);
  transition: background-color 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
}

.shift-tab.active {
  background: linear-gradient(135deg, rgba(255, 232, 223, 0.98) 0%, rgba(255, 247, 236, 0.99) 52%, rgba(240, 247, 255, 0.98) 100%);
  border-color: rgba(244, 198, 185, 0.74);
  box-shadow: 0 16rpx 34rpx rgba(235, 197, 191, 0.24);
}

.tab-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #6b5e79;
}

.tab-time {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #a196ae;
}

.no-shift {
  padding: 60rpx 36rpx;
  text-align: center;
  margin-bottom: 22rpx;
  background:
    radial-gradient(circle at 50% 0, rgba(255, 255, 255, 0.74), transparent 36%),
    linear-gradient(180deg, rgba(250, 246, 255, 0.98) 0%, rgba(255, 255, 255, 0.98) 100%);
}

.no-shift-icon {
  display: block;
  font-size: 78rpx;
  font-weight: 800;
  color: #8f84a9;
}

.no-shift-title {
  display: block;
  margin-top: 20rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #6f627d;
}

.no-shift-text {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.76;
  color: #a79cb3;
}

.btn-check {
  width: 100% !important;
  max-width: 680rpx;
  min-height: 280rpx !important;
  border-radius: 40rpx !important;
  border: 3rpx solid rgba(255, 255, 255, 0.54) !important;
  padding: 0 24rpx !important;
  box-sizing: border-box !important;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  box-shadow:
    0 16rpx 0 rgba(155, 108, 127, 0.2),
    0 30rpx 62rpx rgba(215, 174, 190, 0.34),
    inset 0 6rpx 0 rgba(255, 255, 255, 0.56),
    inset 0 -20rpx 36rpx rgba(94, 56, 80, 0.12);
}

.btn-check.check-in {
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.38) 0%, rgba(255, 255, 255, 0) 34%),
    linear-gradient(145deg, #ffbdb0 0%, #ffbedf 52%, #ffe59d 100%) !important;
  color: #7c4260 !important;
}

.btn-check.check-out {
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.36) 0%, rgba(255, 255, 255, 0) 34%),
    linear-gradient(145deg, #c6d8ff 0%, #cec5ff 52%, #bff0ff 100%) !important;
  color: #516496 !important;
}

.btn-check.checked-out {
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.34) 0%, rgba(255, 255, 255, 0) 34%),
    linear-gradient(145deg, #caefd7 0%, #d7f8f4 52%, #ffe7bc 100%) !important;
  color: #4f8b73 !important;
}

.btn-check[disabled] {
  opacity: 0.96;
}

.btn-beam {
  position: absolute;
  height: 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.5);
  transform: rotate(-10deg);
}

.beam-a {
  top: 30rpx;
  left: 42rpx;
  width: 192rpx;
}

.beam-b {
  top: 60rpx;
  left: 72rpx;
  width: 96rpx;
  opacity: 0.74;
}

.btn-spark {
  position: absolute;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.28);
}

.spark-a {
  top: -22rpx;
  right: 34rpx;
  width: 152rpx;
  height: 152rpx;
}

.spark-b {
  left: 30rpx;
  bottom: 28rpx;
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.16);
}

.spark-c {
  right: 84rpx;
  bottom: 42rpx;
  width: 44rpx;
  height: 44rpx;
  background: rgba(255, 255, 255, 0.62);
}

.btn-text {
  position: relative;
  z-index: 1;
  width: 100%;
  padding: 0 24rpx;
  box-sizing: border-box;
  text-align: center;
  font-size: 46rpx;
  line-height: 1.35;
  font-weight: 800;
  letter-spacing: 4rpx;
  text-shadow:
    0 3rpx 0 rgba(255, 255, 255, 0.16),
    0 10rpx 18rpx rgba(110, 74, 92, 0.14);
}

.shortcut-card {
  padding: 30rpx;
  margin-bottom: 22rpx;
}

.shortcut-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.shortcut-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 22rpx;
}

.shortcut-item {
  width: calc(50% - 8rpx);
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 22rpx;
  border-radius: 26rpx;
  box-sizing: border-box;
  transition: transform 180ms ease, box-shadow 180ms ease, opacity 180ms ease;
}

.shortcut-item.wide {
  width: 100%;
}

.shortcut-item.peach {
  background: linear-gradient(180deg, rgba(255, 243, 244, 0.98) 0%, rgba(255, 255, 255, 1) 100%);
}

.shortcut-item.blue {
  background: linear-gradient(180deg, rgba(239, 245, 255, 0.98) 0%, rgba(255, 255, 255, 1) 100%);
}

.shortcut-item.mint {
  background: linear-gradient(180deg, rgba(237, 251, 246, 0.98) 0%, rgba(255, 255, 255, 1) 100%);
}

.shortcut-item.yellow {
  background: linear-gradient(180deg, rgba(255, 247, 226, 0.98) 0%, rgba(255, 255, 255, 1) 100%);
}

.shortcut-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.82);
  font-size: 30rpx;
  font-weight: 700;
  color: #6d607a;
}

.shortcut-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.shortcut-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #6d607a;
}

.shortcut-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.66;
  color: #a79cb3;
}

.today-record {
  padding: 30rpx;
  background:
    radial-gradient(circle at 90% 10%, rgba(255, 255, 255, 0.7), transparent 28%),
    linear-gradient(180deg, rgba(255, 250, 252, 0.98) 0%, rgba(255, 255, 255, 0.98) 100%);
}

.record-title-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 16rpx;
}

.application-header-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.batch-action-btn {
  flex: none;
  width: 188rpx;
  height: 64rpx;
  line-height: 64rpx;
  margin: 0;
  border-radius: 18rpx;
  font-size: 22rpx;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 24rpx;
}

.record-item {
  padding: 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(255, 248, 251, 0.98) 0%, rgba(255, 255, 255, 0.99) 100%);
  box-shadow: 0 12rpx 28rpx rgba(214, 197, 220, 0.12);
  transition: transform 180ms ease, box-shadow 180ms ease, opacity 180ms ease;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 14rpx;
}

.record-copy {
  display: flex;
  flex-direction: column;
}

.record-shift {
  font-size: 28rpx;
  font-weight: 700;
  color: #6b5d79;
}

.record-window {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #a296ae;
}

.record-times {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 20rpx;
}

.time-block {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.time-label {
  font-size: 22rpx;
  color: #aea6bc;
}

.time-value {
  margin-top: 8rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #70637d;
}

.time-divider {
  width: 1rpx;
  height: 54rpx;
  background: rgba(204, 191, 223, 0.44);
}
