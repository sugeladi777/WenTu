<view class="container">
  <view class="hero-card">
    <view class="hero-copy">
      <text class="hero-kicker">班负签到确认</text>
      <text class="hero-title">{{activeSchedule ? activeSchedule.shiftName : '今日班次'}}</text>
      <text class="hero-subtitle">
        {{activeSchedule ? (activeSchedule.date + ' · ' + activeSchedule.startTime + ' - ' + activeSchedule.endTime) : '今天暂无需要确认的班次'}}
      </text>
    </view>
  </view>

  <scroll-view class="shift-scroll" scroll-x enhanced show-scrollbar="{{false}}" wx:if="{{leaderSchedules.length > 0}}">
    <view class="shift-tabs">
      <view
        class="shift-tab {{activeSchedule && activeSchedule._id === item._id ? 'active' : ''}}"
        wx:for="{{leaderSchedules}}"
        wx:key="_id"
        data-id="{{item._id}}"
        hover-class="tap-soft-hover"
        bindtap="onSwitchShift">
        <text class="tab-title">{{item.shiftName}}</text>
        <text class="tab-sub">{{item.startTime}} - {{item.endTime}}</text>
      </view>
    </view>
  </scroll-view>

  <view class="roster-card card" wx:if="{{roster.length > 0}}">
    <view class="roster-head">
      <view>
        <text class="section-title">班次成员</text>
        <text class="section-desc">先确认签到，再处理加班审批。</text>
      </view>
      <text class="pill pill-ink">{{roster.length}} 人</text>
    </view>

    <view class="roster-list">
      <view class="member-item" wx:for="{{roster}}" wx:key="_id">
        <view class="member-top">
          <view class="member-copy">
            <view class="member-name-row">
              <text class="member-name">{{item.userName}}</text>
              <text class="member-tag {{item.participantTypeClass}}" wx:if="{{item.participantTypeText}}">{{item.participantTypeText}}</text>
            </view>
            <text class="member-meta">学号 {{item.studentId || '--'}} · {{item.startTime}} - {{item.endTime}}</text>
          </view>
          <text class="member-status {{item.leaderConfirmClass}}">{{item.leaderConfirmText}}</text>
        </view>

        <view class="check-row">
          <text class="check-pill {{item.checkInTime ? 'success' : 'muted'}}">
            {{item.checkInTime ? '已自助签到' : '未签到'}}
          </text>
          <text class="check-pill {{item.checkOutTime ? 'success' : 'soft'}}">
            {{item.checkOutTime ? '已签退' : '未签退'}}
          </text>
          <text class="check-pill {{item.attendanceStatus === 3 ? 'danger' : (item.attendanceStatus === 2 ? 'warning' : 'soft')}}">
            {{item.attendanceStatus === 3 ? '旷岗记录' : (item.attendanceStatus === 2 ? '未签退记录' : '考勤正常')}}
          </text>
        </view>

        <view class="action-row" wx:if="{{item.canConfirmPresent || item.canConfirmAbsent}}">
          <button
            wx:if="{{item.canConfirmPresent}}"
            class="action-btn confirm"
            hover-class="tap-button-hover"
            data-id="{{item._id}}"
            bindtap="onConfirmPresent">
            确认签到
          </button>
          <button
            wx:if="{{item.canConfirmAbsent}}"
            class="action-btn absent"
            hover-class="tap-button-hover"
            data-id="{{item._id}}"
            bindtap="onConfirmAbsent">
            标记旷岗
          </button>
        </view>

        <view class="overtime-box">
          <text class="overtime-title">加班申请</text>
          <text class="overtime-status {{item.overtimeClass}}">{{item.overtimeText}}</text>

          <view class="action-row" wx:if="{{item.canReviewOvertime}}">
            <button
              class="action-btn confirm"
              hover-class="tap-button-hover"
              data-id="{{item._id}}"
              bindtap="onApproveOvertime">
              通过加班
            </button>
            <button
              class="action-btn absent"
              hover-class="tap-button-hover"
              data-id="{{item._id}}"
              bindtap="onRejectOvertime">
              驳回加班
            </button>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="empty card" wx:if="{{leaderSchedules.length > 0 && roster.length === 0 && !loading}}">
    <text class="empty-title">这个班次暂无成员</text>
    <text class="empty-text">请稍后再看，或检查是否有人请假后尚未被认领。</text>
  </view>

  <view class="empty card" wx:if="{{leaderSchedules.length === 0 && !loading}}">
    <text class="empty-title">今天没有可确认的班次</text>
    <text class="empty-text">有负责班次时，这里会自动显示成员名单。</text>
  </view>
</view>
