<view class="container">
  <view class="hero-card">
    <text class="hero-kicker">可替班班次</text>
    <text class="hero-title">{{semester ? semester.name : '可替班班次'}}</text>
    <text class="hero-subtitle">查看其他同学发布的请假班次。</text>
  </view>

  <view class="list-card card" wx:if="{{leaveList.length > 0}}">
    <view class="list-header">
      <view>
        <text class="section-title">待认领班次</text>
        <text class="section-desc">选择后可查看详情并认领。</text>
      </view>
    </view>

    <view class="quick-list">
      <view
        class="quick-item"
        wx:for="{{leaveList}}"
        wx:key="_id"
        data-id="{{item._id}}"
        hover-class="tap-card-hover"
        bindtap="onShiftTap">
        <view class="item-glow glow-a"></view>
        <view class="item-glow glow-b"></view>

        <view class="quick-copy">
          <text class="quick-title">{{item.date}} · {{item.shiftName}}</text>
          <text class="quick-sub">{{item.timeRange}} · 请假人 {{item.ownerName}}</text>
          <text class="quick-note">原因：{{item.leaveReasonText}}</text>
        </view>

        <view class="game-button game-button-mini">
          <view class="game-beam beam-a"></view>
          <view class="game-beam beam-b"></view>
          <view class="game-spark spark-a"></view>
          <view class="game-spark spark-b"></view>
          <view class="game-spark spark-c"></view>
          <text class="game-button-text">查看</text>
        </view>
      </view>
    </view>
  </view>

  <view class="empty card" wx:if="{{!loading && leaveList.length === 0}}">
    <text class="empty-title">暂无可替班班次</text>
    <text class="empty-text">有新的请假申请时会出现在这里。</text>
  </view>
</view>
