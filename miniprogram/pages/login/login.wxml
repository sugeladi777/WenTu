<view class="container">
  <view class="hero-panel">
    <view class="logo-stage">
      <view class="book-logo">
        <view class="book-cover left"></view>
        <view class="book-cover right"></view>
        <view class="book-spine"></view>
        <view class="book-page one"></view>
        <view class="book-page two"></view>
      </view>
      <text class="hero-title">文小图</text>
    </view>
  </view>

  <view class="form-section">
    <view class="form-head">
      <text class="form-title">{{mode === 'login' ? '登录账号' : '创建账号'}}</text>
    </view>

    <view class="form-item">
      <text class="label">学号</text>
      <input
        class="input"
        type="number"
        placeholder="请输入学号"
        value="{{studentId}}"
        bindinput="onStudentIdInput"
      />
    </view>

    <view class="form-item">
      <text class="label">密码</text>
      <input
        class="input"
        password
        placeholder="请输入密码"
        value="{{password}}"
        bindinput="onPasswordInput"
      />
    </view>

    <view class="form-item" wx:if="{{mode === 'register'}}">
      <text class="label">姓名</text>
      <input
        class="input"
        placeholder="请输入姓名"
        value="{{name}}"
        bindinput="onNameInput"
      />
    </view>

    <view class="form-item" wx:if="{{mode === 'register'}}">
      <text class="label">昵称</text>
      <input
        class="input"
        placeholder="请输入昵称"
        value="{{nickname}}"
        bindinput="onNicknameInput"
      />
    </view>

    <button
      class="submit-btn {{loading ? 'disabled' : ''}}"
      hover-class="tap-button-hover"
      bindtap="onSubmit"
      disabled="{{loading}}">
      {{mode === 'login' ? '登录账号' : '创建账号'}}
    </button>

    <view class="toggle-mode">
      <text>{{mode === 'login' ? '第一次使用？' : '已经有账号了？'}}</text>
      <text class="link" bindtap="onToggleMode">
        {{mode === 'login' ? '去注册' : '去登录'}}
      </text>
    </view>
  </view>
</view>