.container {
  min-height: 100vh;
  padding: 88rpx 28rpx 64rpx;
  box-sizing: border-box;
}

.hero-panel {
  display: flex;
  justify-content: center;
  padding: 18rpx 0 10rpx;
}

.logo-stage {
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: logo-float 3.4s ease-in-out infinite;
}

.book-logo {
  position: relative;
  width: 174rpx;
  height: 138rpx;
  filter: drop-shadow(0 22rpx 34rpx rgba(218, 185, 200, 0.24));
}

.book-cover {
  position: absolute;
  top: 14rpx;
  width: 78rpx;
  height: 108rpx;
  border-radius: 24rpx 24rpx 28rpx 28rpx;
}

.book-cover.left {
  left: 8rpx;
  background: linear-gradient(180deg, #ffcfdc 0%, #ffe4ef 100%);
  transform: rotate(-8deg);
}

.book-cover.right {
  right: 8rpx;
  background: linear-gradient(180deg, #ffe8b8 0%, #fff5d8 100%);
  transform: rotate(8deg);
}

.book-spine {
  position: absolute;
  left: 50%;
  top: 0;
  width: 36rpx;
  height: 124rpx;
  margin-left: -18rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #cdf0e4 0%, #e3fbf4 100%);
  box-shadow:
    inset 0 0 0 2rpx rgba(255, 255, 255, 0.52),
    0 8rpx 18rpx rgba(205, 221, 214, 0.18);
}

.book-page {
  position: absolute;
  top: 28rpx;
  width: 44rpx;
  height: 76rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.86);
}

.book-page.one {
  left: 48rpx;
  transform: rotate(-8deg);
}

.book-page.two {
  right: 48rpx;
  transform: rotate(8deg);
}

.hero-title {
  margin-top: 20rpx;
  font-size: 56rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
  color: #6f617d;
  text-shadow: 0 8rpx 18rpx rgba(255, 255, 255, 0.34);
}

.form-section {
  margin-top: 28rpx;
  padding: 38rpx 30rpx;
  border-radius: 40rpx;
  background:
    radial-gradient(circle at 92% 8%, rgba(255, 255, 255, 0.82), transparent 28%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(255, 252, 255, 0.92) 100%);
  box-shadow:
    0 24rpx 58rpx rgba(207, 181, 201, 0.18),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.72);
}

.form-head {
  display: flex;
  flex-direction: column;
  margin-bottom: 30rpx;
}

.form-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #6e627c;
}

.form-item {
  margin-bottom: 26rpx;
}

.label {
  display: block;
  margin-bottom: 12rpx;
  padding-left: 4rpx;
  font-size: 24rpx;
  color: #9f93ad;
}

.input {
  width: 100%;
  height: 100rpx;
  border-radius: 28rpx;
  padding: 0 28rpx;
  background: linear-gradient(180deg, rgba(255, 248, 251, 0.98) 0%, rgba(255, 255, 255, 0.98) 100%);
  border: 1rpx solid rgba(236, 224, 241, 0.9);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.64);
  box-sizing: border-box;
  font-size: 28rpx;
  color: #6d617b;
}

.submit-btn {
  width: 100%;
  height: 104rpx;
  margin-top: 22rpx;
  line-height: 104rpx;
  border-radius: 32rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.38) 0%, rgba(255, 255, 255, 0) 32%),
    linear-gradient(145deg, #ffbfb0 0%, #ffc2e1 54%, #ffe6a7 100%);
  color: #7b4560;
  font-size: 32rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  box-shadow:
    0 14rpx 0 rgba(161, 115, 133, 0.16),
    0 28rpx 56rpx rgba(226, 188, 199, 0.28),
    inset 0 4rpx 0 rgba(255, 255, 255, 0.52),
    inset 0 -18rpx 26rpx rgba(130, 82, 103, 0.1);
}

.submit-btn.disabled {
  opacity: 0.72;
}

.toggle-mode {
  margin-top: 26rpx;
  text-align: center;
  font-size: 24rpx;
  color: #a89db7;
}

.link {
  display: inline-flex;
  margin-left: 12rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  color: #c97f93;
  font-weight: 700;
  background: rgba(255, 240, 244, 0.9);
}

@keyframes logo-float {
  0%,
  100% {
    transform: translateY(0);
  }

  50% {
    transform: translateY(-16rpx);
  }
}