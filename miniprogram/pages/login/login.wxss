/* pages/login/login.wxss - 图书馆柔和风格 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f9fc 0%, #ffffff 100%);
  padding: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.logo-section {
  padding: 80rpx 0 60rpx;
  text-align: center;
}

.logo {
  font-size: 100rpx;
  margin-bottom: 20rpx;
  animation: float 3s ease-in-out infinite, glow 2s ease-in-out infinite alternate;
}

@keyframes float {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

@keyframes glow {
  0% {
    filter: drop-shadow(0 0 20rpx rgba(107, 155, 195, 0.5));
  }
  100% {
    filter: drop-shadow(0 0 40rpx rgba(107, 155, 195, 0.9));
  }
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: var(--text-primary);
  letter-spacing: 2rpx;
}

.form-section {
  background: #ffffff;
  margin: 0 40rpx;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  border: 1rpx solid var(--border-color);
  box-shadow: 0 10rpx 40rpx rgba(107, 155, 195, 0.1);
}

.form-item {
  margin-bottom: 35rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  color: var(--primary);
  margin-bottom: 15rpx;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  font-weight: 500;
}

.input {
  width: 100%;
  height: 90rpx;
  padding: 0 25rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 15rpx;
  font-size: 28rpx;
  background: #f8f9fa;
  color: var(--text-primary);
  box-sizing: border-box;
}

.input::placeholder {
  color: #b0bec5;
}

.submit-btn {
  margin-top: 50rpx;
  height: 100rpx;
  line-height: 100rpx;
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 50rpx;
  border: none;
  box-shadow: 0 8rpx 25rpx rgba(107, 155, 195, 0.25);
  letter-spacing: 4rpx;
}

.submit-btn.disabled {
  background: #d0d0d0;
  color: #999;
  box-shadow: none;
}

.toggle-mode {
  text-align: center;
  margin-top: 50rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.link {
  color: var(--primary);
  margin-left: 10rpx;
  font-weight: 500;
}
