/* 登录页面样式 - 马卡龙清新风格 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #faf9f7 0%, #fff5f5 50%, #f0fff0 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.logo-section {
  margin-top: 80rpx;
  margin-bottom: 60rpx;
  text-align: center;
}

.logo {
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(135deg, #ffaaa5 0%, #ffd3b6 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 30rpx;
  box-shadow: 0 10rpx 40rpx rgba(255, 170, 165, 0.4);
  font-size: 100rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #5a5a5a;
  margin-bottom: 10rpx;
}

.form-section {
  width: 100%;
  background: #fff;
  border-radius: 30rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.08);
}

.form-item {
  margin-bottom: 30rpx;
}

.label {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 15rpx;
  display: block;
}

.input {
  width: 100%;
  height: 90rpx;
  background: #faf9f7;
  border: 2rpx solid #ffd3b6;
  border-radius: 20rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.input:focus {
  border-color: #ffaaa5;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #ffaaa5 0%, #ffd3b6 100%);
  color: #fff;
  border: none;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-top: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(255, 170, 165, 0.4);
  line-height: 96rpx;
}

.submit-btn::after {
  border: none;
}

.submit-btn.disabled {
  opacity: 0.7;
}

.toggle-mode {
  text-align: center;
  margin-top: 40rpx;
  font-size: 26rpx;
  color: #aaa;
}

.link {
  color: #ffaaa5;
  margin-left: 10rpx;
}
