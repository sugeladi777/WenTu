<!--pages/myShift/myShift.wxml-->
<view class="container">
  <!-- 学期信息 -->
  <view class="semester-banner" wx:if="{{semester}}">
    <text class="semester-name">{{semester.name}}</text>
  </view>

  <!-- 周滑动视图 -->
  <swiper 
    class="week-swiper" 
    indicator-dots="{{weeklyShifts.length > 1}}"
    current="{{currentWeekIndex}}"
    bindchange="onWeekChange"
    wx:if="{{weeklyShifts.length > 0}}">
    <swiper-item wx:for="{{weeklyShifts}}" wx:for-item="week" wx:key="weekStart">
      <view class="week-card">
        <!-- 星期头部 -->
        <view class="day-header">
          <view class="day-header-cell" wx:for="{{weekDayNames}}" wx:for-index="dayIdx" wx:key="index">
            <text class="day-name">{{item}}</text>
            <text class="day-date">{{week.dates[dayIdx]}}</text>
          </view>
        </view>
        
        <!-- 班次内容 -->
        <view class="day-content">
          <block wx:for="{{week.days}}" wx:for-index="dayIdx" wx:key="index">
            <view class="day-content-cell">
              <block wx:for="{{item}}" wx:for-item="shift" wx:key="_id">
                <view 
                  class="shift-item"
                  data-id="{{shift._id}}"
                  bindtap="onShiftTap">
                  <text class="shift-name">{{shift.shiftName}}</text>
                  <text class="shift-time">{{shift.startTime}}</text>
                </view>
              </block>
            </view>
          </block>
        </view>
      </view>
    </swiper-item>
  </swiper>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{!loading && shiftList.length === 0}}">
    <text>暂无班次安排</text>
    <button class="btn-add" bindtap="onEditShiftTap">去选择班次</button>
  </view>

  <!-- 编辑班次按钮 -->
  <view class="bottom-action" wx:if="{{shiftList.length > 0}}">
    <button class="btn-edit" bindtap="onEditShiftTap">修改班次</button>
  </view>
</view>
