<view class="container">
  <view class="hero-card">
    <text class="hero-kicker">我的班次</text>
    <text class="hero-title">{{semester ? semester.name : '本学期排班'}}</text>
    <text class="hero-subtitle">{{currentWeekLabel || '查看本周排班'}}</text>
  </view>

  <view class="entry-stack">
    <view class="market-entry card" hover-class="tap-card-hover" bindtap="onOpenLeaveMarket">
      <view class="market-orb orb-a"></view>
      <view class="market-orb orb-b"></view>

      <view class="market-copy">
        <text class="market-title">可替班班次</text>
        <text class="market-desc">查看其他同学发布的请假班次。</text>
      </view>

      <view class="game-button game-button-portal">
        <view class="game-beam beam-a"></view>
        <view class="game-beam beam-b"></view>
        <view class="game-spark spark-a"></view>
        <view class="game-spark spark-b"></view>
        <view class="game-spark spark-c"></view>
        <text class="game-button-text">进入查看</text>
      </view>
    </view>

    <view class="market-entry borrow-entry card" hover-class="tap-card-hover" bindtap="onOpenBorrowCenter">
      <view class="market-orb orb-a"></view>
      <view class="market-orb orb-b"></view>

      <view class="market-copy">
        <text class="market-title">添加蹭班</text>
        <text class="market-desc">选择某一天的班次，加入自己的班次列表。</text>
      </view>

      <view class="game-button game-button-portal borrow-button">
        <view class="game-beam beam-a"></view>
        <view class="game-beam beam-b"></view>
        <view class="game-spark spark-a"></view>
        <view class="game-spark spark-b"></view>
        <view class="game-spark spark-c"></view>
        <text class="game-button-text">去添加</text>
      </view>
    </view>
  </view>

  <view class="week-overview card" wx:if="{{weeklyShifts.length > 0}}">
    <text class="week-overview-kicker">本周排班</text>
    <text class="week-overview-text">{{currentWeekLabel}}</text>
  </view>

  <swiper
    class="week-swiper"
    indicator-dots="{{weeklyShifts.length > 1}}"
    current="{{currentWeekIndex}}"
    bindchange="onWeekChange"
    wx:if="{{weeklyShifts.length > 0}}">
    <swiper-item wx:for="{{weeklyShifts}}" wx:for-item="week" wx:key="weekStart">
      <view class="week-card">
        <view class="day-header">
          <view class="day-header-cell" wx:for="{{weekDayNames}}" wx:for-index="dayIdx" wx:key="index">
            <text class="day-name">{{item}}</text>
            <text class="day-date">{{week.dates[dayIdx]}}</text>
          </view>
        </view>

        <view class="day-content">
          <block wx:for="{{week.days}}" wx:key="index">
            <view class="day-content-cell">
              <block wx:if="{{item.length > 0}}">
                <block wx:for="{{item}}" wx:for-item="shift" wx:key="_id">
                  <view
                    class="shift-item {{shift.shiftTypeClass}}"
                    data-id="{{shift._id}}"
                    hover-class="tap-card-hover"
                    bindtap="onShiftTap">
                    <text class="shift-name">{{shift.shiftName}}</text>
                    <text class="shift-time">{{shift.startTime}}</text>
                    <text class="shift-salary" wx:if="{{shift.salaryPaid}}">工资已发</text>
                    <text class="shift-type" wx:if="{{shift.shiftType > 0}}">{{shift.shiftTypeText}}</text>
                  </view>
                </block>
              </block>
            </view>
          </block>
        </view>
      </view>
    </swiper-item>
  </swiper>

  <view class="empty card" wx:if="{{!loading && shiftList.length === 0}}">
    <text class="empty-title">暂无班次安排</text>
    <text class="empty-text">当前没有可显示的排班记录。</text>
  </view>
</view>
