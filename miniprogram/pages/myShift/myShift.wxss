/* pages/myShift/myShift.wxss - 图书馆柔和风格 */
.container {
  padding: 20rpx;
  background: linear-gradient(180deg, #f5f9fc 0%, #ffffff 100%);
  min-height: 100vh;
}

.action-cards {
  display: flex;
  justify-content: space-around;
  padding: 50rpx 30rpx;
  background: #ffffff;
  border: 1rpx solid var(--border-color);
  border-radius: 24rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(107, 155, 195, 0.08);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 40rpx;
  background: #f8f9fa;
  border: 1rpx solid var(--border-color);
  border-radius: 20rpx;
  transition: all 0.3s;
}

.action-item:active {
  background: rgba(107, 155, 195, 0.1);
  border-color: var(--primary);
}

.action-icon {
  font-size: 60rpx;
  margin-bottom: 15rpx;
}

.action-text {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.section-title {
  font-size: 26rpx;
  color: var(--text-primary);
  padding: 20rpx 10rpx 15rpx;
  font-weight: bold;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.shift-list {
  padding: 0;
  background: #ffffff;
  border: 1rpx solid var(--border-color);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 15rpx rgba(107, 155, 195, 0.06);
}

.shift-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.shift-item:last-child {
  border-bottom: none;
}

.shift-date {
  width: 150rpx;
  font-size: 28rpx;
  color: var(--primary);
  font-weight: 500;
}

.shift-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.shift-name {
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.shift-time {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.shift-status {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.shift-status.checked {
  background: rgba(107, 155, 195, 0.1);
  color: var(--primary);
  border: 1rpx solid var(--primary);
}

.shift-status.pending {
  background: rgba(212, 165, 116, 0.15);
  color: #c4956a;
  border: 1rpx solid #d4a574;
}

.shift-status.not-checked {
  background: #f8f9fa;
  color: var(--text-secondary);
  border: 1rpx solid var(--border-color);
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: var(--text-secondary);
  font-size: 28rpx;
}
