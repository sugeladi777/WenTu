/* 我的班次页面样式 - 马卡龙清新风格 */
.container {
  padding: 20rpx;
  background: linear-gradient(180deg, #faf9f7 0%, #fff5f5 100%);
  min-height: 100vh;
}

.semester-banner {
  background: linear-gradient(135deg, #ffaaa5 0%, #ffd3b6 100%);
  color: #fff;
  padding: 25rpx;
  border-radius: 20rpx;
  text-align: center;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 170, 165, 0.3);
}

.semester-name {
  font-size: 32rpx;
  font-weight: bold;
}

.week-swiper {
  height: 500rpx;
  margin-bottom: 20rpx;
}

.week-card {
  padding: 20rpx;
  height: 100%;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.day-header {
  display: flex;
  border-bottom: 2rpx solid #f0f0f0;
  padding-bottom: 15rpx;
  margin-bottom: 15rpx;
}

.day-header-cell {
  flex: 1;
  text-align: center;
}

.day-name {
  display: block;
  font-size: 22rpx;
  color: #aaa;
  margin-bottom: 5rpx;
}

.day-date {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #5a5a5a;
}

.day-content {
  display: flex;
}

.day-content-cell {
  flex: 1;
  min-height: 350rpx;
  border-right: 1rpx solid #f0f0f0;
  padding: 5rpx;
}

.day-content-cell:last-child {
  border-right: none;
}

.shift-item {
  background: linear-gradient(135deg, #a8e6cf 0%, #dcedc1 100%);
  border-radius: 12rpx;
  padding: 10rpx;
  margin-bottom: 8rpx;
}

.shift-name {
  display: block;
  font-size: 22rpx;
  color: #2e8b57;
  font-weight: 600;
}

.shift-time {
  display: block;
  font-size: 20rpx;
  color: #5a5a5a;
  margin-top: 4rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #aaa;
  font-size: 28rpx;
}

.btn-add {
  margin-top: 30rpx;
  background: linear-gradient(135deg, #ffaaa5 0%, #ffd3b6 100%);
  color: #fff;
  border-radius: 50rpx;
  padding: 0 50rpx;
  font-size: 28rpx;
  border: none;
}

.bottom-action {
  padding: 20rpx;
}

.btn-edit {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #ffaaa5 0%, #ffd3b6 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  border: none;
  box-shadow: 0 4rpx 20rpx rgba(255, 170, 165, 0.3);
}

.btn-edit::after {
  border: none;
}
