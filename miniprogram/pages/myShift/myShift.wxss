/* pages/myShift/myShift.wxss */
.container {
  padding: 20rpx;
  background: #f6f6f6;
  min-height: 100vh;
}

.action-cards {
  display: flex;
  justify-content: space-around;
  padding: 40rpx 20rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  font-size: 60rpx;
  margin-bottom: 15rpx;
}

.action-text {
  font-size: 28rpx;
  color: #333;
}

.section-title {
  font-size: 28rpx;
  color: #666;
  padding: 20rpx 10rpx 15rpx;
  font-weight: bold;
}

.shift-list {
  padding: 0;
}

.shift-item {
  display: flex;
  align-items: center;
  padding: 25rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.shift-item:last-child {
  border-bottom: none;
}

.shift-date {
  width: 150rpx;
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.shift-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.shift-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.shift-time {
  font-size: 24rpx;
  color: #999;
}

.shift-status {
  font-size: 24rpx;
  padding: 5rpx 15rpx;
  border-radius: 20rpx;
}

.shift-status.checked {
  background: #e6f7e6;
  color: #3cc51f;
}

.shift-status.pending {
  background: #fff3e6;
  color: #ff9800;
}

.shift-status.not-checked {
  background: #f5f5f5;
  color: #999;
}

.empty-tip {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}
