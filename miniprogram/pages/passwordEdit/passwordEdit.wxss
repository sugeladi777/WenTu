.container {
  padding: 24rpx;
}

.hero-card {
  padding: 36rpx 30rpx;
  border-radius: 40rpx;
  color: #6c6078;
  background:
    radial-gradient(circle at 88% 14%, rgba(255, 255, 255, 0.82), transparent 28%),
    linear-gradient(135deg, #ffe6d9 0%, #fff2c8 46%, #f2e6ff 100%);
  box-shadow:
    0 24rpx 58rpx rgba(221, 193, 205, 0.22),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.68);
}

.hero-kicker {
  display: block;
  font-size: 22rpx;
  letter-spacing: 3rpx;
  opacity: 0.8;
}

.hero-title {
  display: block;
  margin-top: 16rpx;
  font-size: 40rpx;
  font-weight: 800;
}

.hero-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.72;
  color: #8d809f;
}

.editor-card {
  margin-top: 22rpx;
  padding: 30rpx;
  background:
    radial-gradient(circle at 92% 8%, rgba(255, 255, 255, 0.72), transparent 28%),
    linear-gradient(180deg, rgba(255, 249, 252, 0.98) 0%, rgba(255, 255, 255, 0.98) 100%);
}

.form-item {
  margin-top: 24rpx;
}

.form-item:first-child {
  margin-top: 0;
}

.field-label {
  display: block;
  margin-bottom: 12rpx;
  padding-left: 4rpx;
  font-size: 24rpx;
  color: #9f93ad;
}

.field-input {
  width: 100%;
  height: 96rpx;
  padding: 0 26rpx;
  border-radius: 28rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(236, 221, 240, 0.9);
  background: linear-gradient(180deg, rgba(255, 250, 252, 0.98) 0%, rgba(255, 255, 255, 0.98) 100%);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.64);
  color: #6d617b;
  font-size: 28rpx;
}

.primary-btn {
  width: 100%;
  height: 98rpx;
  margin-top: 28rpx;
  line-height: 98rpx;
  border-radius: 30rpx;
  color: #765f76;
  font-size: 30rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.4) 0%, rgba(255, 255, 255, 0) 32%),
    linear-gradient(145deg, #ffbfb0 0%, #ffd5c0 34%, #f2dfff 100%);
  box-shadow:
    0 14rpx 0 rgba(161, 115, 133, 0.16),
    0 28rpx 56rpx rgba(226, 188, 199, 0.26),
    inset 0 4rpx 0 rgba(255, 255, 255, 0.52);
}
