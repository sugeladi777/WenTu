<view class="container">
  <view class="profile-hero {{roleTheme}}">
    <view class="hero-top">
      <view class="avatar-panel">
        <image class="avatar-image" wx:if="{{avatarUrl}}" src="{{avatarUrl}}" mode="aspectFill"></image>
        <text class="avatar-text" wx:else>{{avatarText}}</text>
      </view>

      <view class="hero-copy">
        <text class="display-name">{{displayName}}</text>
        <text class="meta-line">姓名：{{userInfo.name || '--'}}</text>
        <text class="meta-line">学号：{{userInfo.studentId || '--'}}</text>
        <text class="meta-line">当前身份：{{roleText}}</text>
      </view>
    </view>

    <view class="hero-tags">
      <text class="hero-tag accent">{{roleText}}</text>
      <text class="hero-tag">{{grantedRolesText}}</text>
    </view>
  </view>

  <view class="role-switch card" wx:if="{{roleOptions.length > 1}}">
    <view class="section-head">
      <text class="section-title">切换进入身份</text>
      <text class="section-desc">一个账号拥有多个身份时，可以在这里快速切换当前视角。</text>
    </view>

    <view class="role-chip-list">
      <view
        class="role-chip {{item.theme}} {{activeRole === item.role ? 'active' : ''}}"
        wx:for="{{roleOptions}}"
        wx:key="role"
        data-role="{{item.role}}"
        hover-class="tap-card-hover"
        bindtap="onSwitchRole">
        <text class="role-chip-name">{{item.text}}</text>
        <text class="role-chip-desc">{{item.description}}</text>
      </view>
    </view>
  </view>

  <view class="entry-section">
    <view class="entry-card" hover-class="tap-card-hover" bindtap="onOpenProfileEdit">
      <view class="entry-icon peach">资</view>
      <view class="entry-copy">
        <text class="entry-title">账户资料</text>
      </view>
      <text class="entry-arrow">›</text>
    </view>

    <view class="entry-card" hover-class="tap-card-hover" bindtap="onOpenPasswordEdit">
      <view class="entry-icon butter">密</view>
      <view class="entry-copy">
        <text class="entry-title">修改密码</text>
      </view>
      <text class="entry-arrow">›</text>
    </view>
  </view>

  <button class="logout-btn" hover-class="tap-button-hover" bindtap="onLogout">
    退出登录
  </button>
</view>
