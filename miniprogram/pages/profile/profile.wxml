<!--pages/profile/profile.wxml-->
<view class="container">
  <!-- 用户信息卡片 -->
  <view class="profile-header">
    <view class="avatar">
      <text class="avatar-icon">👤</text>
    </view>
    <view class="user-name">{{userInfo.name || '未登录'}}</view>
    <view class="user-role">学号：{{userInfo.studentId || '--'}}</view>
  </view>

  <!-- 菜单列表 -->
  <view class="menu-section">
    <view class="menu-item">
      <view class="menu-icon peach">👤</view>
      <text class="menu-text">我的信息</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item">
      <view class="menu-icon orange">📋</view>
      <text class="menu-text">签到记录</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item">
      <view class="menu-icon green">📊</view>
      <text class="menu-text">工时统计</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item">
      <view class="menu-icon blue">❓</view>
      <text class="menu-text">帮助说明</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 退出登录 -->
  <button class="btn-logout" bindtap="onLogout">
    退出登录
  </button>

  <!-- 版本信息 -->
  <view class="version">文小图 v1.0.0</view>
</view>
