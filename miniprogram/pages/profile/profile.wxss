/* 个人中心页面样式 - 马卡龙清新风格 */
.container {
  padding: 20rpx;
  background: linear-gradient(180deg, #faf9f7 0%, #fff5f5 100%);
  min-height: 100vh;
}

.profile-header {
  background: linear-gradient(135deg, #ffaaa5 0%, #ffd3b6 100%);
  padding: 50rpx 40rpx;
  border-radius: 24rpx;
  text-align: center;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(255, 170, 165, 0.3);
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #fff;
  margin: 0 auto 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.avatar-icon {
  font-size: 70rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.user-role {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.menu-section {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 20rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 50rpx;
  height: 50rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-size: 30rpx;
}

.menu-icon.peach {
  background: linear-gradient(135deg, #ffaaa5 0%, #ffd3b6 100%);
}

.menu-icon.orange {
  background: linear-gradient(135deg, #ffd3b6 0%, #dcedc1 100%);
}

.menu-icon.green {
  background: linear-gradient(135deg, #a8e6cf 0%, #dcedc1 100%);
}

.menu-icon.blue {
  background: linear-gradient(135deg, #dcedc1 0%, #a8e6cf 100%);
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #5a5a5a;
}

.menu-arrow {
  font-size: 24rpx;
  color: #ccc;
}

.btn-logout {
  width: 100%;
  height: 88rpx;
  background: #fff;
  color: #ff6b6b;
  border: none;
  border-radius: 44rpx;
  font-size: 30rpx;
  margin-top: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.btn-logout::after {
  border: none;
}

.version {
  text-align: center;
  font-size: 22rpx;
  color: #ccc;
  margin-top: 30rpx;
}
