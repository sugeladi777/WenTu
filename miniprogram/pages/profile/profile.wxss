/* pages/profile/profile.wxss - 图书馆柔和风格 */
.container {
  padding: 20rpx;
  background: linear-gradient(180deg, #f5f9fc 0%, #ffffff 100%);
  min-height: 100vh;
}

.user-card {
  display: flex;
  align-items: center;
  padding: 50rpx 30rpx;
  background: #ffffff;
  border: 1rpx solid var(--border-color);
  border-radius: 24rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(107, 155, 195, 0.08);
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, var(--primary), var(--secondary));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
  box-shadow: 0 8rpx 25rpx rgba(107, 155, 195, 0.2);
}

.avatar-text {
  font-size: 56rpx;
  color: #fff;
  font-weight: bold;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 15rpx;
}

.user-role {
  font-size: 26rpx;
  color: var(--primary);
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.menu-list {
  padding: 0;
  background: #ffffff;
  border: 1rpx solid var(--border-color);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 15rpx rgba(107, 155, 195, 0.06);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: all 0.3s;
}

.menu-item:active {
  background: rgba(107, 155, 195, 0.05);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 25rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.menu-arrow {
  font-size: 32rpx;
  color: var(--text-secondary);
}

.logout-btn {
  margin-top: 40rpx;
  text-align: center;
  padding: 30rpx 0;
  background: rgba(212, 165, 116, 0.1);
  color: #c4956a;
  font-size: 28rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(212, 165, 116, 0.3);
  font-weight: 500;
  letter-spacing: 2rpx;
}

.logout-btn:active {
  background: rgba(212, 165, 116, 0.15);
}
