.container {
  padding: 24rpx;
}

.hero-card {
  padding: 36rpx 30rpx;
  border-radius: 40rpx;
  color: #6c6078;
  background:
    radial-gradient(circle at 88% 14%, rgba(255, 255, 255, 0.82), transparent 28%),
    linear-gradient(135deg, #ffdce8 0%, #fff0cb 48%, #dff6ef 100%);
  box-shadow:
    0 24rpx 58rpx rgba(221, 193, 205, 0.22),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.68);
}

.hero-kicker {
  display: block;
  font-size: 22rpx;
  letter-spacing: 3rpx;
  opacity: 0.8;
}

.hero-title {
  display: block;
  margin-top: 16rpx;
  font-size: 40rpx;
  font-weight: 800;
}

.hero-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.72;
  color: #8d809f;
}

.editor-card {
  margin-top: 22rpx;
  padding: 30rpx;
  background:
    radial-gradient(circle at 92% 8%, rgba(255, 255, 255, 0.72), transparent 28%),
    linear-gradient(180deg, rgba(255, 249, 252, 0.98) 0%, rgba(255, 255, 255, 0.98) 100%);
}

.avatar-row {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.avatar-panel {
  width: 154rpx;
  height: 154rpx;
  border-radius: 44rpx;
  background: linear-gradient(180deg, rgba(255, 242, 246, 0.98) 0%, rgba(255, 250, 252, 1) 100%);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 14rpx 30rpx rgba(214, 193, 205, 0.18),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.62);
}

.avatar-image {
  width: 100%;
  height: 100%;
}

.avatar-text {
  font-size: 58rpx;
  font-weight: 800;
  color: #6c6078;
}

.avatar-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.avatar-name {
  font-size: 34rpx;
  font-weight: 800;
  color: #6d607b;
}

.avatar-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #a194ae;
}

.ghost-btn,
.primary-btn {
  font-size: 30rpx;
  height: 92rpx;
  line-height: 92rpx;
}

.ghost-btn {
  width: 228rpx;
  margin: 18rpx 0 0;
  border-radius: 28rpx;
  color: #8e7f9d;
  font-weight: 700;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.42) 0%, rgba(255, 255, 255, 0) 30%),
    linear-gradient(135deg, rgba(255, 241, 245, 0.98) 0%, rgba(250, 243, 255, 0.98) 100%);
  box-shadow: 0 12rpx 26rpx rgba(215, 193, 205, 0.16);
}

.form-item {
  margin-top: 24rpx;
}

.field-label {
  display: block;
  margin-bottom: 12rpx;
  padding-left: 4rpx;
  font-size: 24rpx;
  color: #9f93ad;
}

.field-input {
  width: 100%;
  height: 96rpx;
  padding: 0 26rpx;
  border-radius: 28rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(236, 221, 240, 0.9);
  background: linear-gradient(180deg, rgba(255, 250, 252, 0.98) 0%, rgba(255, 255, 255, 0.98) 100%);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.64);
  color: #6d617b;
  font-size: 28rpx;
}

.readonly-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 26rpx;
  background: linear-gradient(135deg, rgba(255, 246, 249, 0.98) 0%, rgba(251, 248, 255, 0.98) 100%);
}

.readonly-label {
  font-size: 24rpx;
  color: #9f93ad;
}

.readonly-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #6d617b;
}

.primary-btn {
  width: 100%;
  margin-top: 28rpx;
  border-radius: 30rpx;
  color: #765f76;
  font-weight: 800;
  letter-spacing: 2rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.4) 0%, rgba(255, 255, 255, 0) 32%),
    linear-gradient(145deg, #ffbfb0 0%, #ffc2e1 54%, #ffe6a7 100%);
  box-shadow:
    0 14rpx 0 rgba(161, 115, 133, 0.16),
    0 28rpx 56rpx rgba(226, 188, 199, 0.26),
    inset 0 4rpx 0 rgba(255, 255, 255, 0.52);
}
