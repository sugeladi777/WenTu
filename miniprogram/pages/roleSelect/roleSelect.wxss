.role-page {
  min-height: 100vh;
  padding: 96rpx 28rpx 72rpx;
  box-sizing: border-box;
}

.hero {
  position: relative;
  overflow: hidden;
  padding: 42rpx 32rpx 36rpx;
  background:
    radial-gradient(circle at 88% 14%, rgba(255, 239, 200, 0.78), transparent 24%),
    radial-gradient(circle at 12% 18%, rgba(255, 227, 234, 0.88), transparent 30%),
    linear-gradient(160deg, rgba(255, 255, 255, 0.96) 0%, rgba(251, 255, 253, 0.94) 100%);
}

.hero::after {
  content: '';
  position: absolute;
  right: -46rpx;
  bottom: -52rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(214, 235, 255, 0.36) 0%, rgba(214, 235, 255, 0) 70%);
}

.hero-kicker {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  color: #d78c86;
}

.hero-title {
  display: block;
  margin-top: 14rpx;
  font-size: 44rpx;
  font-weight: 800;
  color: #5f586f;
}

.hero-desc {
  display: block;
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #9389a5;
}

.profile-chip {
  position: relative;
  z-index: 1;
  display: inline-flex;
  flex-direction: column;
  margin-top: 26rpx;
  padding: 18rpx 22rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.8);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.56);
}

.profile-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #645b75;
}

.profile-id {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #9a90aa;
}

.role-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 28rpx;
}

.role-card {
  padding: 28rpx 24rpx;
  border-radius: 30rpx;
  border: 2rpx solid transparent;
  box-shadow:
    0 18rpx 32rpx rgba(215, 201, 213, 0.14),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.6);
}

.role-card.member {
  background: linear-gradient(135deg, rgba(255, 241, 244, 0.96) 0%, rgba(255, 250, 252, 0.98) 100%);
}

.role-card.leader {
  background: linear-gradient(135deg, rgba(255, 244, 221, 0.96) 0%, rgba(255, 251, 241, 0.98) 100%);
}

.role-card.admin {
  background: linear-gradient(135deg, rgba(225, 241, 250, 0.96) 0%, rgba(246, 251, 255, 0.98) 100%);
}

.role-card.active {
  border-color: rgba(223, 166, 177, 0.92);
  transform: translateY(-2rpx);
}

.role-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.role-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #665d75;
}

.role-tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #c6798c;
  background: rgba(255, 255, 255, 0.74);
}

.role-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.72;
  color: #978da8;
}

.enter-btn,
.back-btn {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  border-radius: 30rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.enter-btn {
  margin-top: 30rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.42) 0%, rgba(255, 255, 255, 0) 34%),
    linear-gradient(145deg, #ffbcb1 0%, #ffc8d5 50%, #ffdca9 100%);
  color: #7c4d63;
  box-shadow:
    0 16rpx 34rpx rgba(227, 192, 198, 0.24),
    inset 0 4rpx 0 rgba(255, 255, 255, 0.54);
}

.back-btn {
  margin-top: 18rpx;
  background: rgba(255, 255, 255, 0.78);
  color: #8b84a1;
  box-shadow:
    0 10rpx 24rpx rgba(216, 206, 222, 0.18),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.62);
}