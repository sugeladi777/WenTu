<!--pages/selectSchedule/selectSchedule.wxml-->
<view class="container">
  <!-- 学期信息卡片 -->
  <view class="card semester-card" wx:if="{{semester}}">
    <text class="semester-name">{{semester.name}}</text>
    <text class="semester-date">{{semester.startDate}} 至 {{semester.endDate}}</text>
  </view>

  <!-- 无班次模板 -->
  <view class="empty" wx:if="{{!loading && shiftTemplates.length === 0}}">
    <text>当前学期暂无班次模板</text>
    <text class="empty-hint">请联系管理员设置班次</text>
  </view>

  <!-- 横向滚动容器 -->
  <scroll-view class="table-scroll" scroll-x wx:if="{{shiftTemplates.length > 0}}">
    <!-- 班次表格 -->
    <view class="schedule-table">
      <!-- 表头：星期 -->
      <view class="table-header">
        <view class="th shift-col">班次</view>
        <view 
          class="th weekday-col"
          wx:for="{{weekDays}}" 
          wx:key="index">
          <text class="day-name">{{item}}</text>
        </view>
      </view>

      <!-- 表格内容：每个班次一行 -->
      <view 
        class="table-row"
        wx:for="{{shiftTemplates}}"
        wx:for-index="shiftIdx"
        wx:key="_id">
        <view class="td shift-col">
          <text class="shift-name">{{item.name}}</text>
          <text class="shift-time">{{item.startTime}}-{{item.endTime}}</text>
        </view>
        <view 
          class="td weekday-col"
          wx:for="{{weekDays}}"
          wx:for-index="dayIdx"
          wx:key="index"
          data-shiftidx="{{shiftIdx}}"
          data-dayidx="{{dayIdx}}"
          bindtap="onSelectShift">
          <view class="shift-btn {{selectedMatrix[shiftIdx][dayIdx] ? 'selected' : ''}}">
            <text class="btn-check" wx:if="{{selectedMatrix[shiftIdx][dayIdx]}}">✓</text>
            <text class="btn-count" wx:else>{{capacityMatrix[shiftIdx][dayIdx].remaining}}</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 提交按钮 -->
  <view class="submit-section" wx:if="{{shiftTemplates.length > 0}}">
    <button class="submit-btn" bindtap="onSubmit" loading="{{loading}}">
      确认班次
    </button>
  </view>
</view>
