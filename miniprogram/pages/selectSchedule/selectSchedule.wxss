/* pages/selectSchedule/selectSchedule.wxss */
.container {
  padding: 20rpx;
  background-color: #f5f9fc;
  min-height: 100vh;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.semester-card {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.semester-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.semester-date {
  font-size: 24rpx;
  color: #999;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #999;
}

.empty-hint {
  font-size: 24rpx;
  margin-top: 20rpx;
}

.table-scroll {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.schedule-table {
  display: inline-block;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.table-header {
  display: flex;
  background: #6b9bc3;
  color: #fff;
}

.table-row {
  display: flex;
  border-bottom: 1rpx solid #eee;
}

.table-row:last-child {
  border-bottom: none;
}

.th, .td {
  padding: 20rpx;
  text-align: center;
  font-size: 26rpx;
}

.shift-col {
  width: 180rpx;
  background: #f8f8f8;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.shift-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.shift-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 5rpx;
}

.weekday-col {
  width: 100rpx;
}

.day-name {
  font-size: 26rpx;
}

.shift-btn {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
}

.shift-btn.selected {
  background: #6b9bc3;
  color: #fff;
}

.shift-btn.full {
  background: #ffebee;
}

.btn-check {
  font-size: 28rpx;
}

.btn-count {
  font-size: 22rpx;
  color: #666;
}

.btn-count.full-count {
  color: #e53935;
}

.submit-section {
  padding: 20rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #6b9bc3;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  border: none;
}

.submit-btn::after {
  border: none;
}
