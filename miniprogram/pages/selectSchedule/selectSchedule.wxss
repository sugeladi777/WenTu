/* 班次选择页面样式 - 马卡龙清新风格 */
.container {
  padding: 20rpx;
  background: linear-gradient(180deg, #faf9f7 0%, #fff5f5 100%);
  min-height: 100vh;
}

.semester-card {
  background: linear-gradient(135deg, #a8e6cf 0%, #dcedc1 100%);
  border-radius: 20rpx;
  padding: 25rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.semester-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #2e8b57;
  margin-bottom: 10rpx;
}

.semester-date {
  display: block;
  font-size: 24rpx;
  color: #5a5a5a;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  color: #aaa;
  font-size: 28rpx;
}

.empty-hint {
  font-size: 24rpx;
  margin-top: 15rpx;
  color: #ccc;
}

.table-scroll {
  white-space: nowrap;
  margin-bottom: 150rpx;
}

.schedule-table {
  display: inline-block;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.table-header {
  display: flex;
  background: linear-gradient(135deg, #faf9f7 0%, #fff5f5 100%);
}

.th {
  padding: 25rpx 15rpx;
  text-align: center;
  font-size: 26rpx;
  color: #5a5a5a;
  font-weight: 600;
}

.th.shift-col {
  width: 180rpx;
  min-width: 180rpx;
}

.th.weekday-col {
  width: 100rpx;
  min-width: 100rpx;
}

.table-row {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.td {
  padding: 20rpx 15rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.td.shift-col {
  width: 180rpx;
  min-width: 180rpx;
  border-right: 1rpx solid #f0f0f0;
}

.td.weekday-col {
  width: 100rpx;
  min-width: 100rpx;
  border-right: 1rpx solid #f0f0f0;
}

.td.weekday-col:last-child {
  border-right: none;
}

.shift-name {
  display: block;
  font-size: 26rpx;
  color: #5a5a5a;
  font-weight: 600;
}

.shift-time {
  display: block;
  font-size: 20rpx;
  color: #aaa;
  margin-top: 5rpx;
}

.shift-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #faf9f7;
  border: 2rpx solid #dcedc1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.shift-btn.selected {
  background: linear-gradient(135deg, #ffaaa5 0%, #ffd3b6 100%);
  border-color: #ffaaa5;
}

.btn-check {
  font-size: 28rpx;
  color: #fff;
}

.btn-count {
  font-size: 24rpx;
  color: #aaa;
}

.submit-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 30rpx 40rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #ffaaa5 0%, #ffd3b6 100%);
  color: #fff;
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 20rpx rgba(255, 170, 165, 0.3);
}

.submit-btn::after {
  border: none;
}
