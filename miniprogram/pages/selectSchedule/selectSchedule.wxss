/* pages/selectSchedule/selectSchedule.wxss */
.container {
  padding: 20rpx;
  background: linear-gradient(180deg, #f5f9fc 0%, #ffffff 100%);
  min-height: 100vh;
  padding-bottom: 150rpx;
}

.header {
  text-align: center;
  padding: 40rpx 0;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #3d4f5f;
  margin-bottom: 15rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #7a8b9a;
}

/* 横向滚动 */
.table-scroll {
  white-space: nowrap;
  padding-bottom: 20rpx;
}

/* 表格 */
.schedule-table {
  display: inline-flex;
  flex-direction: column;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 5rpx 30rpx rgba(107, 155, 195, 0.15);
  margin: 0 10rpx;
}

/* 表头 */
.table-header {
  display: flex;
  background: linear-gradient(135deg, #6b9bc3, #a8c5de);
  color: #fff;
}

.table-header .th {
  padding: 25rpx 15rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-right: 1rpx solid rgba(255,255,255,0.3);
}

.table-header .th:last-child {
  border-right: none;
}

.table-header .th.shift-col {
  width: 160rpx;
  background: rgba(0,0,0,0.15);
}

.table-header .th.weekday-col {
  width: 140rpx;
}

.day-name {
  font-size: 28rpx;
  font-weight: bold;
}

/* 表格行 */
.table-row {
  display: flex;
  border-bottom: 1rpx solid #e0e0e0;
}

.table-row:last-child {
  border-bottom: none;
}

.table-row .td {
  padding: 20rpx 15rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-right: 1rpx solid #e0e0e0;
}

.table-row .td:last-child {
  border-right: none;
}

.table-row .td.shift-col {
  width: 160rpx;
  background: #f8f9fa;
}

.table-row .td.weekday-col {
  width: 140rpx;
}

.shift-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #3d4f5f;
  margin-bottom: 5rpx;
}

.shift-time {
  font-size: 20rpx;
  color: #7a8b9a;
}

/* 班次按钮 */
.shift-btn {
  width: 110rpx;
  height: 80rpx;
  background: #f5f5f5;
  border: 3rpx solid #cccccc;
  border-radius: 15rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.shift-btn.selected {
  background: linear-gradient(135deg, #6b9bc3, #a8c5de);
  border-color: #6b9bc3;
  box-shadow: 0 5rpx 15rpx rgba(107, 155, 195, 0.4);
}

.shift-btn-hover {
  transform: scale(0.95);
  opacity: 0.8;
}

.btn-time {
  font-size: 24rpx;
  font-weight: bold;
  color: #7a8b9a;
  line-height: 1.3;
}

.shift-btn.selected .btn-time {
  color: #ffffff;
}

/* 提交按钮 */
.submit-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 40rpx;
  background: #ffffff;
  box-shadow: 0 -5rpx 20rpx rgba(0, 0, 0, 0.08);
}

.submit-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  background: linear-gradient(135deg, #6b9bc3, #a8c5de);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 45rpx;
  border: none;
}
