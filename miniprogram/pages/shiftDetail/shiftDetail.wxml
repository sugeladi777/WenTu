<view class="container">
  <view class="header-card" wx:if="{{shift}}">
    <text class="header-kicker">{{shift.date}}</text>
    <text class="header-title">{{shift.shiftName}}</text>
    <view class="header-tags">
      <text class="header-tag {{shift.attendanceClass}}">{{shift.attendanceText}}</text>
      <text class="header-tag soft">{{shift.startTime}} - {{shift.endTime}}</text>
      <text class="header-tag salary" wx:if="{{shift.salaryPaid}}">工资已发</text>
      <text class="header-tag soft" wx:if="{{source === 'market'}}">可替班</text>
      <text class="header-tag soft" wx:if="{{canAdminEdit}}">管理员视角</text>
    </view>
  </view>

  <view class="card detail-card" wx:if="{{shift}}">
    <view class="section">
      <view class="section-title">基本信息</view>
      <view class="info-row">
        <text class="info-label">日期</text>
        <text class="info-value">{{shift.date}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">班次类型</text>
        <text class="info-value">{{shift.shiftTypeText}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">班次工时</text>
        <text class="info-value">{{shift.fixedHoursDisplay}} 小时</text>
      </view>
      <view class="info-row">
        <text class="info-label">时段</text>
        <text class="info-value">{{shift.startTime}} - {{shift.endTime}}</text>
      </view>
      <view class="info-row" wx:if="{{canAdminEdit}}">
        <text class="info-label">记录 ID</text>
        <text class="info-value info-id">{{shift._id}}</text>
      </view>
    </view>

    <view class="section" wx:if="{{shift.showLeaveSection}}">
      <view class="section-title">请假信息</view>
      <view class="info-row">
        <text class="info-label">请假人</text>
        <text class="info-value">{{shift.leaveOwnerName}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">请假状态</text>
        <text class="info-value {{shift.leaveProgressClass || shift.attendanceClass}}">{{shift.leaveStatusText}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">请假原因</text>
        <text class="info-value">{{shift.leaveReasonText}}</text>
      </view>
      <view class="info-row" wx:if="{{shift.replacementUserName}}">
        <text class="info-label">替班同学</text>
        <text class="info-value text-primary">{{shift.replacementName}}</text>
      </view>
    </view>

    <view class="section" wx:if="{{shift.showSwapSection}}">
      <view class="section-title">替班信息</view>
      <view class="info-row">
        <text class="info-label">替班类型</text>
        <text class="info-value text-swap">{{shift.shiftTypeText}}</text>
      </view>
      <view class="info-row" wx:if="{{shift.originalOwnerName}}">
        <text class="info-label">原班次同学</text>
        <text class="info-value">{{shift.originalOwnerName}}</text>
      </view>
    </view>

    <view class="section" wx:if="{{shift.showBorrowSection}}">
      <view class="section-title">蹭班信息</view>
      <view class="info-row">
        <text class="info-label">班次类型</text>
        <text class="info-value text-primary">{{shift.shiftTypeText}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">当前状态</text>
        <text class="info-value text-primary">{{shift.borrowStatusText}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">班负</text>
        <text class="info-value">{{shift.borrowLeaderText}}</text>
      </view>
    </view>

    <view class="section">
      <view class="section-title">考勤信息</view>
      <view class="info-row">
        <text class="info-label">签到时间</text>
        <text class="info-value {{shift.checkInTime ? 'text-primary' : 'text-muted'}}">
          {{shift.checkInTime ? shift.checkInTimeLabel : '未签到'}}
        </text>
      </view>
      <view class="info-row">
        <text class="info-label">签退时间</text>
        <text class="info-value {{shift.checkOutTime ? 'text-primary' : 'text-muted'}}">
          {{shift.checkOutTime ? shift.checkOutTimeLabel : '未签退'}}
        </text>
      </view>
      <view class="info-row">
        <text class="info-label">考勤状态</text>
        <text class="info-value {{shift.attendanceClass}}">{{shift.attendanceText}}</text>
      </view>
      <view class="info-row" wx:if="{{shift.showLeaderConfirmRow}}">
        <text class="info-label">班负确认</text>
        <text class="info-value {{shift.leaderConfirmClass}}">{{shift.leaderConfirmText}}</text>
      </view>
    </view>

    <view class="section">
      <view class="section-title">工时统计</view>
      <view class="info-row">
        <text class="info-label">实际工时</text>
        <text class="info-value text-primary">{{shift.actualHoursDisplay}} 小时</text>
      </view>
      <view class="info-row">
        <text class="info-label">申请加班</text>
        <text class="info-value">{{shift.overtimeHoursDisplay}} 小时</text>
      </view>
      <view class="info-row">
        <text class="info-label">加班状态</text>
        <text class="info-value {{shift.overtimeClass}}">{{shift.overtimeText}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">是否有效</text>
        <text class="info-value {{shift.validClass}}">{{shift.validText}}</text>
      </view>
    </view>

    <view class="section">
      <view class="section-title">工资信息</view>
      <view class="info-row">
        <text class="info-label">工资状态</text>
        <text class="info-value {{shift.salaryPaid ? 'text-primary' : 'text-muted'}}">{{shift.salaryStatusText}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">发放金额</text>
        <text class="info-value">¥{{shift.salaryAmountDisplay}}</text>
      </view>
      <view class="info-row" wx:if="{{shift.salaryPaid}}">
        <text class="info-label">发放时薪</text>
        <text class="info-value">¥{{shift.salaryRateDisplay}} / 小时</text>
      </view>
      <view class="info-row" wx:if="{{shift.salaryPaid}}">
        <text class="info-label">发放时间</text>
        <text class="info-value">{{shift.salaryPaidAtDisplay}}</text>
      </view>
      <view class="salary-hint">{{shift.salaryHint}}</view>
    </view>
  </view>

  <view class="card action-card" wx:if="{{shift && shift.showOvertimeSection}}">
    <view class="section">
      <view class="section-title">加班申请</view>
      <text class="action-desc">{{shift.overtimeHint}}</text>

      <view class="info-row compact-row">
        <text class="info-label">当前状态</text>
        <text class="info-value {{shift.overtimeClass}}">{{shift.overtimeText}}</text>
      </view>

      <textarea
        class="reason-textarea"
        wx:if="{{shift.canSubmitOvertime}}"
        maxlength="10"
        placeholder="填写加班时长，例如 1 或 1.5"
        value="{{overtimeHoursInput}}"
        bindinput="onOvertimeInput"
      ></textarea>

      <button
        class="action-btn overtime"
        wx:if="{{shift.canSubmitOvertime}}"
        hover-class="tap-button-hover"
        loading="{{loading}}"
        bindtap="onSubmitOvertimeRequest">
        {{shift.overtimeButtonText}}
      </button>
    </view>
  </view>

  <view class="card action-card" wx:if="{{shift && canAdminEdit}}">
    <view class="section">
      <view class="edit-head">
        <view class="edit-copy">
          <view class="section-title">管理员编辑</view>
          <text class="action-desc">编辑服务器中的原始班次记录。除 `_id` 外，其他字段均可修改。</text>
        </view>
        <button
          class="edit-toggle-btn"
          hover-class="tap-button-hover"
          disabled="{{!adminRawLoaded || adminRawLoading || loading}}"
          bindtap="onToggleEditMode">
          {{isEditMode ? '取消编辑' : '开始编辑'}}
        </button>
      </view>

      <view class="admin-state">
        <text class="admin-state-text {{adminRawLoaded ? 'text-success' : 'text-warning'}}">
          {{adminRawLoaded ? '已加载服务器原始记录' : '正在加载服务器原始记录'}}
        </text>
        <button
          class="mini-ghost-btn"
          hover-class="tap-button-hover"
          loading="{{adminRawLoading}}"
          disabled="{{adminRawLoading || loading}}"
          bindtap="onReloadAdminRaw">
          重新加载
        </button>
      </view>

      <view wx:if="{{isEditMode}}">
        <textarea
          class="json-textarea"
          maxlength="-1"
          auto-height
          value="{{editJsonText}}"
          bindinput="onAdminJsonInput"
        ></textarea>

        <view class="admin-edit-actions">
          <button
            class="secondary-btn subtle"
            hover-class="tap-button-hover"
            disabled="{{adminRawLoading || loading}}"
            bindtap="onReloadAdminRaw">
            恢复当前记录
          </button>

          <button
            class="action-btn admin-save"
            hover-class="tap-button-hover"
            loading="{{loading}}"
            bindtap="onSaveAdminEdit">
            保存完整记录
          </button>
        </view>
      </view>
    </view>
  </view>

  <view class="card action-card" wx:if="{{shift && (shift.canApplyLeave || shift.canClaimReplacement)}}">
    <view class="section">
      <view class="section-title">{{shift.actionTitle}}</view>
      <text class="action-desc">{{shift.actionDesc}}</text>

      <textarea
        class="reason-textarea"
        wx:if="{{shift.canApplyLeave}}"
        maxlength="120"
        placeholder="填写请假原因"
        value="{{leaveReasonInput}}"
        bindinput="onReasonInput"
      ></textarea>

      <button
        class="action-btn leave"
        wx:if="{{shift.canApplyLeave}}"
        hover-class="tap-button-hover"
        loading="{{loading}}"
        bindtap="onApplyLeave">
        发布请假班次
      </button>

      <button
        class="action-btn swap"
        wx:if="{{shift.canClaimReplacement}}"
        hover-class="tap-button-hover"
        loading="{{loading}}"
        bindtap="onClaimShift">
        我要替班
      </button>
    </view>
  </view>

  <view class="empty card" wx:if="{{!shift && !loading}}">
    <text class="empty-title">数据加载失败</text>
    <text class="empty-subtitle">请返回上一页后重新打开这条记录。</text>
  </view>
</view>
