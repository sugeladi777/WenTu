/* 班次详情页面样式 */
.container {
  padding: 20rpx;
  background: linear-gradient(180deg, #faf9f7 0%, #fff5f5 100%);
  min-height: 100vh;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.section {
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section:last-child {
  border-bottom: none;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
  border-left: 6rpx solid #ffaaa5;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 10rpx;
}

.info-row:not(:last-child) {
  border-bottom: 1rpx solid #f5f5f5;
}

.info-label {
  font-size: 28rpx;
  color: #888;
  flex-shrink: 0;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  text-align: right;
  margin-left: 20rpx;
  word-break: break-all;
}

.info-value.small {
  font-size: 22rpx;
  color: #aaa;
}

.text-success { color: #2e8b57; }
.text-warning { color: #ff9800; }
.text-danger { color: #f44336; }
.text-muted { color: #aaa; }
.text-primary { color: #2e8b57; font-weight: 600; }
.text-leave { color: #9c27b0; }
.text-swap { color: #2196f3; }
.text-borrow { color: #ff5722; }

.empty {
  text-align: center;
  padding: 100rpx;
  color: #aaa;
  font-size: 28rpx;
}
