.container {
  padding: 24rpx;
}

.header-card {
  padding: 36rpx 30rpx;
  border-radius: 40rpx;
  background:
    radial-gradient(circle at 88% 14%, rgba(255, 255, 255, 0.82), transparent 28%),
    linear-gradient(135deg, #ffe1d6 0%, #e5ddff 54%, #dff4ea 100%);
  color: #6b6078;
  box-shadow:
    0 24rpx 56rpx rgba(217, 189, 210, 0.24),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.64);
}

.header-kicker {
  display: block;
  font-size: 22rpx;
  letter-spacing: 3rpx;
  opacity: 0.8;
}

.header-title {
  display: block;
  margin-top: 16rpx;
  font-size: 42rpx;
  font-weight: 800;
}

.header-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 22rpx;
}

.header-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: rgba(255, 255, 255, 0.56);
  color: #74678a;
}

.header-tag.soft {
  background: rgba(255, 255, 255, 0.44);
  color: #867999;
}

.header-tag.salary {
  background: rgba(223, 233, 255, 0.9);
  color: #7d90c7;
}

.header-tag.text-success {
  background: rgba(217, 242, 231, 0.9);
}

.header-tag.text-warning {
  background: rgba(255, 231, 205, 0.94);
}

.header-tag.text-danger {
  background: rgba(255, 222, 227, 0.94);
}

.header-tag.text-muted {
  background: rgba(236, 228, 246, 0.94);
}

.detail-card,
.action-card {
  margin-top: 20rpx;
}

.detail-card {
  padding: 10rpx 0;
  background:
    radial-gradient(circle at 92% 8%, rgba(255, 255, 255, 0.7), transparent 28%),
    linear-gradient(180deg, rgba(255, 249, 252, 0.98) 0%, rgba(255, 255, 255, 0.98) 100%);
}

.action-card {
  background:
    radial-gradient(circle at 92% 8%, rgba(255, 255, 255, 0.7), transparent 28%),
    linear-gradient(180deg, rgba(255, 248, 251, 0.98) 0%, rgba(255, 255, 255, 0.98) 100%);
}

.section {
  padding: 26rpx 28rpx;
}

.section + .section {
  border-top: 1rpx solid rgba(224, 213, 242, 0.5);
}

.section-title {
  margin-bottom: 18rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #6c6078;
}

.info-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding: 16rpx 0;
}

.info-row:not(:last-child) {
  border-bottom: 1rpx solid rgba(227, 216, 243, 0.46);
}

.compact-row {
  padding-bottom: 0;
}

.info-label {
  font-size: 26rpx;
  color: #a396af;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  text-align: right;
  color: #6d607a;
  word-break: break-all;
}

.info-id {
  font-size: 22rpx;
  color: #9b8faa;
}

.action-desc {
  display: block;
  font-size: 24rpx;
  line-height: 1.72;
  color: #9388a5;
}

.salary-hint {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #a093af;
}

.edit-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.edit-copy {
  flex: 1;
}

.edit-toggle-btn {
  min-width: 170rpx;
  height: 72rpx;
  padding: 0 24rpx;
  line-height: 72rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #846f93;
  background: linear-gradient(135deg, rgba(245, 238, 252, 0.98) 0%, rgba(255, 247, 242, 0.98) 100%);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.54),
    0 10rpx 20rpx rgba(216, 194, 217, 0.12);
}

.admin-state {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.54);
}

.admin-state-text {
  flex: 1;
  font-size: 24rpx;
}

.mini-ghost-btn {
  min-width: 148rpx;
  height: 64rpx;
  margin: 0;
  padding: 0 22rpx;
  line-height: 64rpx;
  border-radius: 22rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #8a7395;
  background: linear-gradient(135deg, rgba(247, 240, 252, 0.98) 0%, rgba(255, 248, 243, 0.98) 100%);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.54),
    0 10rpx 20rpx rgba(216, 194, 217, 0.12);
}

.json-textarea,
.reason-textarea {
  width: 100%;
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(255, 250, 252, 0.98) 0%, rgba(255, 255, 255, 0.98) 100%);
  border: 1rpx solid rgba(236, 221, 240, 0.9);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.64);
  box-sizing: border-box;
  color: #6d617b;
}

.reason-textarea {
  min-height: 190rpx;
  font-size: 26rpx;
}

.json-textarea {
  min-height: 520rpx;
  font-size: 24rpx;
  line-height: 1.72;
  font-family: monospace;
}

.admin-edit-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 22rpx;
}

.secondary-btn.subtle {
  width: 100%;
  height: 82rpx;
  line-height: 82rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #8a7395;
  background: linear-gradient(135deg, rgba(247, 240, 252, 0.98) 0%, rgba(255, 248, 243, 0.98) 100%);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.54),
    0 10rpx 20rpx rgba(216, 194, 217, 0.12);
}

.action-btn {
  width: 100%;
  height: 98rpx;
  margin-top: 24rpx;
  line-height: 98rpx;
  border-radius: 30rpx;
  font-size: 30rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  box-shadow:
    0 14rpx 0 rgba(173, 143, 170, 0.14),
    0 28rpx 48rpx rgba(221, 190, 210, 0.2),
    inset 0 4rpx 0 rgba(255, 255, 255, 0.52);
}

.action-btn.leave {
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.38) 0%, rgba(255, 255, 255, 0) 32%),
    linear-gradient(145deg, #ffbfb0 0%, #ffc2e1 54%, #ffe6a7 100%);
  color: #76506f;
}

.action-btn.swap {
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.38) 0%, rgba(255, 255, 255, 0) 32%),
    linear-gradient(145deg, #cdeedc 0%, #d7e4ff 54%, #fff0b8 100%);
  color: #6788a1;
}

.action-btn.overtime {
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.38) 0%, rgba(255, 255, 255, 0) 32%),
    linear-gradient(145deg, #cdeedc 0%, #f3d8ff 52%, #fff0b8 100%);
  color: #6f7ea6;
}

.action-btn.admin-save {
  margin-top: 0;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.38) 0%, rgba(255, 255, 255, 0) 32%),
    linear-gradient(145deg, #ffc3b5 0%, #ffd7c4 46%, #e7dcff 100%);
  color: #7c627e;
}

.text-success {
  color: #6aa28c;
}

.text-warning {
  color: #cc9568;
}

.text-danger {
  color: #ce8894;
}

.text-muted {
  color: #a89fb7;
}

.text-primary {
  color: #7c90c6;
}

.text-swap {
  color: #7d90c8;
}

.empty {
  margin-top: 20rpx;
  padding: 84rpx 30rpx;
  text-align: center;
  background:
    radial-gradient(circle at 50% 0, rgba(255, 255, 255, 0.76), transparent 36%),
    linear-gradient(180deg, rgba(250, 246, 255, 0.98) 0%, rgba(255, 255, 255, 0.98) 100%);
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #6c6078;
}

.empty-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.72;
  color: #a69bb4;
}
