.container {
  padding: 24rpx;
}

.summary-card {
  padding: 36rpx 30rpx 30rpx;
  border-radius: 40rpx;
  box-shadow:
    0 24rpx 58rpx rgba(221, 193, 205, 0.22),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.68);
  color: #6c6078;
  background:
    radial-gradient(circle at 88% 14%, rgba(255, 255, 255, 0.82), transparent 28%),
    linear-gradient(135deg, #ffdbe8 0%, #fff0ca 48%, #dcf6ee 100%);
}

.summary-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
}

.summary-kicker {
  display: block;
  font-size: 22rpx;
  letter-spacing: 3rpx;
  opacity: 0.8;
}

.summary-title {
  display: block;
  margin-top: 14rpx;
  font-size: 40rpx;
  font-weight: 800;
}

.summary-badge {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: rgba(255, 255, 255, 0.58);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.68);
}

.summary-hours {
  display: flex;
  align-items: baseline;
  margin-top: 30rpx;
}

.hours-number {
  font-size: 92rpx;
  font-weight: 800;
  line-height: 1;
}

.hours-unit {
  margin-left: 12rpx;
  font-size: 28rpx;
  opacity: 0.84;
}

.summary-money {
  display: block;
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #85789b;
}

.summary-stats {
  display: flex;
  gap: 14rpx;
  margin-top: 26rpx;
}

.summary-chip {
  flex: 1;
  padding: 18rpx 18rpx 16rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.54);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.7);
}

.summary-chip-value {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
}

.summary-chip-label {
  display: block;
  margin-top: 6rpx;
  font-size: 20rpx;
  opacity: 0.78;
}

.view-tabs {
  display: flex;
  gap: 8rpx;
  padding: 10rpx;
  margin: 20rpx 0;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 16rpx 34rpx rgba(207, 184, 205, 0.16);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 26rpx;
  color: #aaa0b8;
  border-radius: 20rpx;
  transition: transform 180ms ease, box-shadow 180ms ease, opacity 180ms ease;
}

.tab-item.active {
  background: linear-gradient(135deg, rgba(255, 225, 217, 0.98) 0%, rgba(244, 236, 255, 0.98) 56%, rgba(228, 246, 239, 0.96) 100%);
  color: #6d607a;
  font-weight: 700;
  box-shadow: 0 12rpx 26rpx rgba(221, 194, 204, 0.18);
}

.records-card {
  padding: 30rpx;
  background:
    radial-gradient(circle at 90% 10%, rgba(255, 255, 255, 0.7), transparent 28%),
    linear-gradient(180deg, rgba(255, 249, 252, 0.98) 0%, rgba(255, 255, 255, 0.98) 100%);
}

.records-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 18rpx;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 24rpx;
}

.record-card {
  padding: 28rpx 24rpx;
  border-radius: 30rpx;
  background: linear-gradient(180deg, rgba(255, 248, 251, 0.98) 0%, rgba(255, 255, 255, 0.99) 100%);
  box-shadow:
    0 14rpx 30rpx rgba(214, 197, 220, 0.12),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.62);
  transition: transform 180ms ease, box-shadow 180ms ease, opacity 180ms ease;
}

.record-top,
.record-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.record-date {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.record-day {
  font-size: 30rpx;
  font-weight: 800;
  color: #6b5d78;
}

.record-week {
  font-size: 22rpx;
  color: #a69bb4;
}

.record-status {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.record-status.tone-success {
  background: rgba(217, 242, 231, 0.92);
  color: #6ba28d;
}

.record-status.tone-warning {
  background: rgba(255, 231, 205, 0.94);
  color: #c68f63;
}

.record-status.tone-danger {
  background: rgba(255, 222, 227, 0.94);
  color: #cd8794;
}

.record-status.tone-muted {
  background: rgba(236, 228, 246, 0.94);
  color: #8f82a9;
}

.record-main {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
}

.record-shift {
  font-size: 30rpx;
  font-weight: 700;
  color: #6b5d78;
}

.record-range {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #a79cb3;
}

.record-bottom {
  margin-top: 22rpx;
}

.record-meta {
  display: flex;
  gap: 14rpx;
  align-items: center;
  flex-wrap: wrap;
}

.record-hours,
.record-paid {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: #faf5fc;
  color: #9388a4;
}

.record-hours.is-valid {
  background: rgba(216, 242, 230, 0.9);
  color: #6ba28d;
}

.record-paid.is-paid {
  background: rgba(223, 233, 255, 0.92);
  color: #7e92c7;
}

.record-arrow {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #aa9fbb;
  background: rgba(246, 240, 252, 0.9);
}

.empty-tip {
  padding: 84rpx 24rpx 72rpx;
  text-align: center;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #6c6078;
}

.empty-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.74;
  color: #a69bb4;
}
