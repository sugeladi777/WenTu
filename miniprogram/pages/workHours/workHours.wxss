/* 工时页面样式 - 马卡龙清新风格 */
.container {
  padding: 20rpx;
  background: linear-gradient(180deg, #faf9f7 0%, #fff5f5 100%);
  min-height: 100vh;
}

.summary-card {
  background: linear-gradient(135deg, #ffaaa5 0%, #ffd3b6 100%);
  border-radius: 20rpx;
  padding: 40rpx;
  text-align: center;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 30rpx rgba(255, 170, 165, 0.3);
}

.summary-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 15rpx;
}

.summary-hours {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.hours-number {
  font-size: 80rpx;
  font-weight: bold;
  color: #fff;
  line-height: 1;
}

.hours-unit {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-left: 10rpx;
}

.view-tabs {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 28rpx;
  color: #aaa;
  border-radius: 12rpx;
}

.tab-item.active {
  background: linear-gradient(135deg, #a8e6cf 0%, #dcedc1 100%);
  color: #2e8b57;
  font-weight: 600;
}

.list-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.list-header {
  display: flex;
  padding: 25rpx;
  background: linear-gradient(135deg, #faf9f7 0%, #fff5f5 100%);
  border-bottom: 1rpx solid #f0f0f0;
}

.col-date, .col-shift, .col-hours {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #aaa;
  font-weight: 600;
}

.list-item {
  display: flex;
  padding: 25rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.list-item:last-child {
  border-bottom: none;
}

.col-date, .col-shift, .col-hours {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #5a5a5a;
}

.col-hours.text-primary {
  color: #2e8b57;
  font-weight: 600;
}

.empty-tip {
  text-align: center;
  padding: 80rpx;
  color: #aaa;
  font-size: 28rpx;
}
