/* pages/workHours/workHours.wxss - 图书馆柔和风格 */
.container {
  padding: 20rpx;
  background: linear-gradient(180deg, #f5f9fc 0%, #ffffff 100%);
  min-height: 100vh;
}

.summary-card {
  text-align: center;
  padding: 60rpx 30rpx;
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  color: #fff;
  border-radius: 24rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(107, 155, 195, 0.25);
}

.summary-title {
  font-size: 28rpx;
  margin-bottom: 20rpx;
  opacity: 0.9;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.summary-hours {
  display: flex;
  justify-content: center;
  align-items: baseline;
}

.hours-number {
  font-size: 100rpx;
  font-weight: bold;
  color: #fff;
}

.hours-unit {
  font-size: 32rpx;
  margin-left: 15rpx;
  opacity: 0.9;
}

.view-tabs {
  display: flex;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 8rpx;
  margin: 20rpx 0;
  border: 1rpx solid var(--border-color);
  box-shadow: 0 4rpx 15rpx rgba(107, 155, 195, 0.06);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: var(--text-secondary);
  border-radius: 15rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  color: #fff;
  font-weight: 500;
  box-shadow: 0 4rpx 15rpx rgba(107, 155, 195, 0.25);
}

.list-card {
  padding: 0;
  background: #ffffff;
  border: 1rpx solid var(--border-color);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 15rpx rgba(107, 155, 195, 0.06);
}

.list-header {
  display: flex;
  padding: 25rpx 30rpx;
  background: rgba(107, 155, 195, 0.05);
  font-size: 26rpx;
  color: var(--primary);
  border-bottom: 1rpx solid var(--border-color);
}

.list-item {
  display: flex;
  padding: 25rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  color: var(--text-secondary);
}

.list-item:last-child {
  border-bottom: none;
}

.col-date {
  width: 200rpx;
  color: var(--text-primary);
}

.col-shift {
  flex: 1;
  color: var(--text-secondary);
}

.col-hours {
  width: 100rpx;
  text-align: right;
  color: var(--primary);
  font-weight: 500;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: var(--text-secondary);
  font-size: 28rpx;
}
